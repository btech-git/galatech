<?php

class PurchaseInvoiceController extends Controller {

    public function filters() {
        return array(
            'access',
        );
    }

    public function filterAccess($filterChain) {
        $taxCreateValid = Yii::app()->user->checkAccess('tAccountingCreate') || Yii::app()->user->checkAccess('tsAccountingCreate');
        $nonTaxCreateValid = Yii::app()->user->checkAccess('ntAccountingCreate');
        $taxEditValid = Yii::app()->user->checkAccess('tAccountingEdit') || Yii::app()->user->checkAccess('tsAccountingEdit');
        $nonTaxEditValid = Yii::app()->user->checkAccess('ntAccountingEdit');

        if ($filterChain->action->id === 'create') {
            $params = $filterChain->controller->actionParams;

            if (isset($params['id'])) {
                if (!($taxEditValid || $nonTaxEditValid))
                    $this->redirect(array('/site/login'));
            } else {
                if (isset($params['nt'])) {
                    if (!$nonTaxCreateValid)
                        $this->redirect(array('/site/login'));
                } else {
                    if (!$taxCreateValid)
                        $this->redirect(array('/site/login'));
                }
            }
        }
        if ($filterChain->action->id === 'purchaseAjaxData' || $filterChain->action->id === 'memo' || $filterChain->action->id === 'view') {
            if (!($taxCreateValid || $nonTaxCreateValid || $taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'delete' || $filterChain->action->id === 'admin') {
            if (!($taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'report') {
            if (!(Yii::app()->user->checkAccess('ntAccountingReport') || Yii::app()->user->checkAccess('tAccountingReport') || Yii::app()->user->checkAccess('tsAccountingReport')))
                $this->redirect(array('/site/login'));
        }

        $filterChain->run();
    }

    public function actionCreate() {
        $purchaseInvoice = new PurchaseInvoiceTransaction();

        if (isset($_GET['id']))
            $purchaseInvoice->copyFromDb($_GET['id']);

        if ($purchaseInvoice->header->isNewRecord) {
            $purchaseInvoice->header->is_non_tax = intval(isset($_GET['nt']));
            $purchaseInvoice->header->number = CodeNumber::make($purchaseInvoice->header, 'number', ($purchaseInvoice->header->is_non_tax) ? 'NTTP' : 'TTP', ($purchaseInvoice->header->is_non_tax) ? true : false);
        }

        $purchaseInvoice->header->admin_id = Yii::app()->user->id;
        $this->loadState($purchaseInvoice);

        $purchaseHeader = new PurchaseHeader('search');
        $purchaseHeader->unsetAttributes();  // clear any default values
        if (isset($_GET['PurchaseHeader']))
            $purchaseHeader->attributes = $_GET['PurchaseHeader'];

        $error = false;

        if (isset($_POST['Submit']) && IdempotentManager::check()) {
            if ($purchaseInvoice->header->isNewRecord) {
                $purchaseInvoice->header->is_non_tax = intval(isset($_GET['nt']));
                $purchaseInvoice->header->number = CodeNumber::make($purchaseInvoice->header, 'number', ($purchaseInvoice->header->is_non_tax) ? 'NTTP' : 'TTP', ($purchaseInvoice->header->is_non_tax) ? true : false);
            }

            $dbTransaction = CActiveRecord::$db->beginTransaction();
            try {
                if ($purchaseInvoice->validate() && IdempotentManager::build()->save() && $purchaseInvoice->save(false)) {
                    $dbTransaction->commit();
                    Yii::app()->session['PurchaseInvoiceMemoAllowed'] = true;
                    $this->redirect(array('view', 'id' => $purchaseInvoice->header->id));
                } else {
                    $dbTransaction->rollback();
                    $error = true;
                }
            } catch (Exception $e) {
                $dbTransaction->rollback();
                throw new CHttpException($e->getCode(), $e->getMessage());
            }
        }

        $this->render('create', array(
            'purchaseInvoice' => $purchaseInvoice,
            'purchaseHeader' => $purchaseHeader,
            'error' => $error,
        ));
    }

    public function actionPurchaseAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchaseInvoice = new PurchaseInvoiceTransaction();

            if (!empty($id))
                $purchaseInvoice->copyFromDb($id);

            $this->loadState($purchaseInvoice);

            $object = array(
                'purchase_header_number' => $purchaseInvoice->header->purchaseHeader->number,
                'supplier_company' => $purchaseInvoice->header->purchaseHeader->supplier->company,
                'totalPurchase' => Yii::app()->numberFormatter->format('#,##0.00', $purchaseInvoice->header->totalPurchase),
            );

            echo CJSON::encode($object);
        }
    }

    public function actionView($id) {
        $purchaseInvoice = PurchaseInvoice::model()->findByPk($id);

        $this->render('view', array(
            'purchaseInvoice' => $purchaseInvoice,
        ));
    }

    public function actionMemo($id) {
        if (!(Yii::app()->user->checkAccess('administrator'))) {
            if (!(isset(Yii::app()->session['PurchaseInvoiceMemoAllowed']) && Yii::app()->session['PurchaseInvoiceMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('PurchaseInvoiceMemoAllowed');

        $purchaseInvoice = PurchaseInvoice::model()->findByPk($id);

        $purchaseInvoiceSupplier = ($purchaseInvoice->is_non_tax) ? $purchaseInvoice->purchaseHeader->supplier->name : $purchaseInvoice->purchaseHeader->supplier->company;
        $purchaseInvoiceHeaderText = ($purchaseInvoice->is_non_tax) ? '' : 'PT. Galatech';

        $this->render('memo', array(
            'purchaseInvoice' => $purchaseInvoice,
            'purchaseInvoiceSupplier' => $purchaseInvoiceSupplier,
            'purchaseInvoiceHeaderText' => $purchaseInvoiceHeaderText,
        ));
    }

    public function actionAdmin() {
        $purchaseInvoice = new PurchaseInvoice('search');
        $purchaseInvoice->unsetAttributes();

        if (isset($_GET['PurchaseInvoice']))
            $purchaseInvoice->attributes = $_GET['PurchaseInvoice'];

        $supplierId = (isset($_GET['SupplierId'])) ? $_GET['SupplierId'] : '';

        $dataProvider = $purchaseInvoice->search();
        $dataProvider->criteria->join = "INNER JOIN tblgt_purchase_header purchaseHeader ON (t.purchase_header_id = purchaseHeader.id) AND (purchaseHeader.is_inactive = 0)";
        $dataProvider->criteria->compare('purchaseHeader.supplier_id', $supplierId);
        $dataProvider->criteria->with = array('admin:resetScope');
        $dataProvider->model->resetScope();

        $this->render('admin', array(
            'purchaseInvoice' => $purchaseInvoice,
            'dataProvider' => $dataProvider,
            'supplierId' => $supplierId,
        ));
    }

    public function actionDelete($id) {
        if (Yii::app()->request->isPostRequest) {
            $purchaseInvoice = PurchaseInvoice::model()->findByPk($id);
            if ($purchaseInvoice !== null) {
                $purchaseInvoice->is_inactive = !$purchaseInvoice->is_inactive;
                $purchaseInvoice->update(array('is_inactive'));
            }

            if (!isset($_GET['ajax']))
                $this->redirect(isset($_POST['returnUrl']) ? $_POST['returnUrl'] : array('admin'));
        } else
            throw new CHttpException(400, 'Invalid request. Please do not repeat this request again.');
    }

    public function actionReport() {
        $purchaseInvoice = new PurchaseInvoice('search');
        $purchaseInvoice->unsetAttributes();
        if (isset($_GET['PurchaseInvoice']))
            $purchaseInvoice->attributes = $_GET['PurchaseInvoice'];

        $startDate = (isset($_GET['StartDate'])) ? $_GET['StartDate'] : '';
        $endDate = (isset($_GET['EndDate'])) ? $_GET['EndDate'] : '';
        $pageSize = (isset($_GET['PageSize'])) ? $_GET['PageSize'] : '';
        $currentPage = (isset($_GET['page'])) ? $_GET['page'] : '';
        $currentSort = (isset($_GET['sort'])) ? $_GET['sort'] : '';

        $supplierId = (isset($_GET['SupplierId'])) ? $_GET['SupplierId'] : '';

        $dataProvider = $purchaseInvoice->search();
        $dataProvider->criteria->compare('purchaseHeader.supplier_id', $supplierId);
        $dataProvider->criteria->with = array('purchaseHeader.supplier');

        $page = array('size' => $pageSize, 'current' => $currentPage);
        $date = array('attribute' => 't.date', 'start' => $startDate, 'end' => $endDate);

        $sort = new CSort(get_class($purchaseInvoice));
        $sort->attributes = array('date');

        $dataProvider = ReportHelper::finalizeDataProvider($dataProvider, $page, $sort, $date);

        $this->render('report', array(
            'purchaseInvoice' => $purchaseInvoice,
            'dataProvider' => $dataProvider,
            'startDate' => $startDate,
            'endDate' => $endDate,
            'sort' => $sort,
            'currentSort' => $currentSort,
            'supplierId' => $supplierId,
        ));
    }

    protected function loadState(&$purchaseInvoice) {
        if (isset($_POST['PurchaseInvoice'])) {
            $purchaseInvoice->header->attributes = $_POST['PurchaseInvoice'];
        }
    }
}
