    public function actionSummaryAjaxData($id, $index) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesCheque = new SalesCheque();

            if (!empty($id))
                $salesCheque->copyFromDb($id);

            if (!isset($_POST['SalesChequeDetail']))
                $salesCheque->details = array();

            $this->loadState($salesCheque);

            $amount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($salesCheque->details[$index], 'amount')));
            $total = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($salesCheque, 'total')));

            echo CJSON::encode(array(
                'amount' => $amount,
                'total' => $total,
            ));
        }
    }

    public function actionAjaxHtmlAddReceipt($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesCheque = new SalesCheque();
            $this->loadState($salesCheque);

            if (isset($_POST['ReceiptId']))
                $salesCheque->addSalesReceipt($_POST['ReceiptId']);

            $salesChequeAccountCategorySecondary = 'id IN (1, 48, 288, 160, 161, 3, 370, 467)';
            $salesChequeAccountCategoryPrimary = 'id IN (2, 47, 260, 160, 161, 463, 586, 595)';

            $this->renderPartial('_detail', array(
                'salesCheque' => $salesCheque,
                'salesChequeAccountCategorySecondary' => $salesChequeAccountCategorySecondary,
                'salesChequeAccountCategoryPrimary' => $salesChequeAccountCategoryPrimary,
                'error' => false,
            ));
        }
    }

    public function actionView($id) {
        $salesCheque = SalesChequeHeader::model()->findByPk($id);

        $this->render('view', array(
            'salesCheque' => $salesCheque,
        ));
    }

    public function actionMemo($id) {
        if (!(Yii::app()->user->checkAccess('administrator'))) {
            if (!(isset(Yii::app()->session['SalesChequeMemoAllowed']) && Yii::app()->session['SalesChequeMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('SalesChequeMemoAllowed');

        $salesCheque = SalesChequeHeader::model()->findByPk($id);

        $salesChequeCustomer = ($salesCheque->is_non_tax) ? $salesCheque->customer->name : $salesCheque->customer->company;
        $salesChequeHeaderText = ($salesCheque->is_non_tax) ? '' : 'PT. Galatech Jaya Abadi';

        $this->render('memo', array(
            'salesCheque' => $salesCheque,
            'salesChequeHeaderText' => $salesChequeHeaderText,
            'salesChequeCustomer' => $salesChequeCustomer,
        ));
    }

    public function actionAdmin() {
        $salesCheque = new SalesChequeHeader('search');
        $salesCheque->unsetAttributes();

        if (isset($_GET['SalesChequeHeader']))
            $salesCheque->attributes = $_GET['SalesChequeHeader'];

//		$customerId = (isset($_GET['CustomerId'])) ? $_GET['CustomerId'] : '';

        $dataProvider = $salesCheque->search();
//		$dataProvider->criteria->join = "INNER JOIN tblgt_sales_cheque_detail salesChequeDetail ON t.id = salesChequeDetail.sales_cheque_header_id INNER JOIN tblgt_receipt_header receiptHeader ON salesChequeDetail.receipt_header_id = receiptHeader.id";
//		$dataProvider->criteria->compare('receiptHeader.customer_id', $customerId);

        $this->render('admin', array(
            'salesCheque' => $salesCheque,
            'dataProvider' => $dataProvider,
//			'customerId' => $customerId,
        ));
    }

    public function actionDelete($id) {
        if (Yii::app()->request->isPostRequest) {
            $salesCheque = SalesChequeHeader::model()->findByPk($id);
            if ($salesCheque !== null) {
                $salesCheque->is_inactive = !$salesCheque->is_inactive;
                $salesCheque->update(array('is_inactive'));
            }

            if (!isset($_GET['ajax']))
                $this->redirect(isset($_POST['returnUrl']) ? $_POST['returnUrl'] : array('admin'));
        } else
            throw new CHttpException(400, 'Invalid request. Please do not repeat this request again.');
    }

    public function actionAjaxHtmlRemoveDetail($index) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesCheque = new SalesCheque();

            $this->loadState($salesCheque);

            $salesCheque->removeDetailAt($index);

            $this->renderPartial('_detail', array(
                'salesCheque' => $salesCheque,
                'error' => false,
            ));
        }
    }

    public function actionCustomerAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesCheque = new SalesCheque();

            if (!empty($id))
                $salesCheque->copyFromDb($id);

            if (!isset($_POST['SalesChequeDetail']))
                $salesCheque->details = array();

            $this->loadState($salesCheque);

            $object = array(
                'customer_id' => $salesCheque->header->customer->company,
                'customer_name' => $salesCheque->header->customer->name,
                'customer_address' => $salesCheque->header->customer->address,
            );
            echo CJSON::encode($object);
        }
    }

    public function actionAjaxHtmlResetDetail() {
        if (Yii::app()->request->isAjaxRequest) {
            $salesCheque = new SalesCheque();

            $this->loadState($salesCheque);

            if (isset($_POST['SalesChequeHeader']['customer_id']))
                $salesCheque->resetDetail($_POST['SalesChequeHeader']['customer_id']);

            $this->renderPartial('_detail', array(
                'salesCheque' => $salesCheque,
                'error' => false,
            ));
        }
    }

    public function actionReport() {
        $salesCheque = new SalesChequeHeader('search');
        $salesCheque->unsetAttributes();
        if (isset($_GET['SalesChequeHeader']))
            $salesCheque->attributes = $_GET['SalesChequeHeader'];

        $startDate = (isset($_GET['StartDate'])) ? $_GET['StartDate'] : '';
        $endDate = (isset($_GET['EndDate'])) ? $_GET['EndDate'] : '';
        $pageSize = (isset($_GET['PageSize'])) ? $_GET['PageSize'] : '';
        $currentPage = (isset($_GET['page'])) ? $_GET['page'] : '';
        $currentSort = (isset($_GET['sort'])) ? $_GET['sort'] : '';
//		$supplierId = (isset($_GET['SupplierId'])) ? $_GET['SupplierId'] : '';

        $dataProvider = $salesCheque->search();
//		$dataProvider->criteria->compare('purchaseReceiptHeader.supplier_id', $supplierId);
//		$dataProvider->criteria->join = "INNER JOIN " . PurchaseReceiptHeader::model()->tableName() . " purchaseReceiptHeader ON purchaseReceiptHeader.id = t.purchase_receipt_header_id INNER JOIN " . Supplier::model()->tableName() . " supplier ON purchaseReceiptHeader.supplier_id = supplier.id";

        $page = array('size' => $pageSize, 'current' => $currentPage);
        $date = array('attribute' => 't.receive_date', 'start' => $startDate, 'end' => $endDate);

        $sort = new CSort(get_class($salesCheque));
//		$sort->attributes = array('receive_date', 'supplier.name');
        $sort->attributes = array('receive_date');

        $dataProvider = ReportHelper::finalizeDataProvider($dataProvider, $page, $sort, $date);

        $this->render('report', array(
            'salesCheque' => $salesCheque,
            'dataProvider' => $dataProvider,
            'startDate' => $startDate,
            'endDate' => $endDate,
            'sort' => $sort,
            'currentSort' => $currentSort,
//			'supplierId' => $supplierId,
        ));
    }

    protected function loadState($salesCheque) {
        if (isset($_POST['SalesChequeHeader'])) {
            $salesCheque->header->attributes = $_POST['SalesChequeHeader'];
        }
        if (isset($_POST['SalesChequeDetail'])) {
            foreach ($_POST['SalesChequeDetail'] as $i => $item) {
                if (isset($salesCheque->details[$i]))
                    $salesCheque->details[$i]->attributes = $item;
                else {
                    $detail = new SalesChequeDetail();
                    $detail->attributes = $item;
                    $salesCheque->details[] = $detail;
                }
            }
            if (count($_POST['SalesChequeDetail']) < count($salesCheque->details))
                array_splice($salesCheque->details, $i + 1);
        }
    }
}
