<?php

class Delivery extends CComponent
{
	public $header;
	public $details;

	public function __construct()
	{
		$this->header = new DeliveryHeader();
		$this->details = array();
	}

	public function copyFromDb($id)
	{
		$this->header = DeliveryHeader::model()->resetScope()->findByPk($id);
		$this->details = DeliveryDetail::model()->resetScope()->findAllByAttributes(array('delivery_header_id' => $id));
	}

	public function addProduct($id)
	{
		$product = Product::model()->findByPk($id);

		if ($product !== null)
		{
			$exist = false;
			foreach ($this->details as $i => $detail)
			{
				if ($product->id === $detail->product_id)
				{
					$exist = true;
					break;
				}
			}

			if ($exist)
				$this->details[$i]->quantity++;
			else
			{
				$detail = new DeliveryDetail();
				$detail->product_id = $product->id;
				$detail->product_name = $product->name;
				$detail->unit_price = $product->selling_price;
				$detail->average_purchase_price = $product->weighted_purchase_price;
				$this->details[] = $detail;
			}
		}
	}

	public function removeProductAt($index)
	{
		array_splice($this->details, $index, 1);
	}

	public function validate()
	{
		$valid = $this->header->validate();

		if ($this->header->is_non_tax || count($this->details) > 0)
		{
			foreach ($this->details as $detail)
			{
				$fields = array('quantity', 'product_id');
				$valid = $detail->validate($fields) && $valid;
			}
		}
		else
			$valid = false;

		return $valid;
	}

	public function save($runValidation)
	{
		$valid = $this->header->save($runValidation);

		Inventory::model()->deleteAllByAttributes(array('transaction_number' => $this->header->number));

		if (TaxConnectionChecking::isCurrentConnectionPrimary() || (TaxConnectionChecking::isCurrentConnectionSecondary() && TaxConnectionChecking::nonTaxValid()))
		{
			$accountingJournalDebit = AccountingJournalHelper::make(
				'debit', 
				$this->header->number, 
				$this->header->date, 
				$this->header->customer->account_id, 
				$this->grandTotal
			);
			$valid = $accountingJournalDebit->save() && $valid;
			
			$accountingJournalCredit = AccountingJournalHelper::make(
				'credit', 
				$this->header->number, 
				$this->header->date, 
				27, 
				$this->totalBeforeTax
			);
			$valid = $accountingJournalCredit->save() && $valid;
			
			$journalTaxCredit = AccountingJournalHelper::make(
				'credit', 
				$this->header->number, 
				$this->header->date, 
				173, 
				$this->calculatedTax
			);
			$valid = $accountingJournalCredit->save() && $valid;
			
			$journalTaxCredit = AccountingJournalHelper::make(
				'credit', 
				$this->header->number, 
				$this->header->date, 
				174, 
				$this->header->shipping_fee
			);
			$valid = $accountingJournalCredit->save() && $valid;
		}
		
		foreach ($this->details as $detail)
		{
			$detail->delivery_header_id = $this->header->id;
			$detail->average_purchase_price = $detail->product->weighted_purchase_price;
			$valid = $detail->save($runValidation) && $valid;

			if ((int)$detail->is_inactive === 0)
			{
				$inventory = new Inventory();
				$inventory->transaction_number = $this->header->number;
				$inventory->transaction_type = 5;
				$inventory->transaction_subject = $this->header->customer->company;
				$inventory->product_id = $detail->product_id;
				$inventory->admin_id = $this->header->admin_id;
				$inventory->date = $this->header->date;
				$inventory->quantity_out = $detail->quantity;
				$inventory->warehouse_id = $this->header->warehouse_id;

				$valid = $inventory->save() && $valid;
			}
		}

		return $valid;
	}

	public function getSubTotal()
	{
		$total = 0.00;
		foreach ($this->details as $detail)
			$total += $detail->total;

		return $total;
	}
        
        public function getSubTotalQuantity()
	{
		$total = 0.00;
		foreach ($this->details as $detail)
			$total += $detail->quantity;

		return $total;
	}

	public function getCalculatedDiscount()
	{
		return $this->subTotal * $this->header->discount / 100;
	}

	public function getCalculatedTax()
	{
		return $this->totalBeforeTax * $this->header->tax / 100;
	}

	public function getGrandTotal()
	{
		return $this->totalBeforeTax + $this->calculatedTax + $this->header->shipping_fee;
	}

	public function getTotalBeforeTax()
	{
		return $this->subTotal - $this->calculatedDiscount - (($this->header->salesDownpayment === null) ? 0 : $this->header->downpayment_amount);
	}
}
