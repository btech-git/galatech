<br />

<table style="width: 90%; margin: 0 auto; border-spacing: 0pt">
        <tr>
            <th style="width: 15%; text-align: center; font-size: larger; border-bottom: 1px solid">Transaksi #</th>
            <th style="width: 17%; text-align: center; font-size: larger; border-bottom: 1px solid">Tanggal</th>
            <th style="width: 10%; text-align: center; font-size: larger; border-bottom: 1px solid">Account</th>
            <th style="width: 25%; text-align: center; font-size: larger; border-bottom: 1px solid">Keterangan</th>
            <th style="width: 10%; text-align: center; font-size: larger; border-bottom: 1px solid">Debit</th>
            <th style="width: 10%; text-align: center; font-size: larger; border-bottom: 1px solid">Credit</th>
            <th style="width: 10%; text-align: center; font-size: larger; border-bottom: 1px solid">Saldo</th>
        </tr>
		<?php $initialBalance = $account->getBeginningBalance($accountId, $startDate); ?>
		<tr>
			<td colspan="5" style="font-weight: bold; text-align: right">SALDO AWAL</td>
			<td colspan="2" style="font-weight: bold; text-align: right"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', $initialBalance)); ?></td>
		</tr>
		<?php $totalDebit = 0.00; ?>
		<?php $totalCredit = 0.00; ?>
        <?php foreach ($dataProvider->data as $data): ?>
			<?php $debit = $data['debit']; ?>
			<?php $credit = $data['credit']; ?>
			<?php $totalDebit += $debit; ?>
			<?php $totalCredit += $credit; ?>
			<?php $balance = $initialBalance + $debit - $credit; ?>
			<tr>
				<td><?php echo CHtml::encode($data['number']); ?></td>
				<td style="text-align: center"><?php echo CHtml::encode(Yii::app()->dateFormatter->format('d MMMM yyyy', strtotime($data['date']))); ?></td>
				<td style="text-align: center"><?php echo CHtml::encode($data['code']); ?></td>
				<td><?php echo CHtml::encode($data['account']); ?></td>
				<td style="text-align: right"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', $debit)); ?></td>
				<td style="text-align: right"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', $credit)); ?></td>
				<td style="text-align: right"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', $balance)); ?></td>
			</tr>
			<?php $initialBalance = $balance; ?>
        <?php endforeach; ?>
