<?php

class ChequeController extends Controller {

    public function filters() {
        return array(
            'access',
        );
    }

    public function filterAccess($filterChain) {
        $taxCreateValid = Yii::app()->user->checkAccess('tAccountingCreate') || Yii::app()->user->checkAccess('tsAccountingCreate');
        $nonTaxCreateValid = Yii::app()->user->checkAccess('ntAccountingCreate');
        $taxEditValid = Yii::app()->user->checkAccess('tAccountingEdit') || Yii::app()->user->checkAccess('tsAccountingEdit');
        $nonTaxEditValid = Yii::app()->user->checkAccess('ntAccountingEdit');

        if ($filterChain->action->id === 'create') {
            $params = $filterChain->controller->actionParams;

            if (isset($params['id'])) {
                if (!($taxEditValid || $nonTaxEditValid))
                    $this->redirect(array('/site/login'));
            } else {
                if (isset($params['nt'])) {
                    if (!$nonTaxCreateValid)
                        $this->redirect(array('/site/login'));
                } else {
                    if (!$taxCreateValid)
                        $this->redirect(array('/site/login'));
                }
            }
        }
        if ($filterChain->action->id === 'invoiceAjaxData' || $filterChain->action->id === 'amountAjaxData' || $filterChain->action->id === 'memo' || $filterChain->action->id === 'view') {
            if (!($taxCreateValid || $nonTaxCreateValid || $taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'delete' || $filterChain->action->id === 'admin') {
            if (!($taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'report') {
            if (!(Yii::app()->user->checkAccess('ntAccountingReport') || Yii::app()->user->checkAccess('tAccountingReport') || Yii::app()->user->checkAccess('tsAccountingReport')))
                $this->redirect(array('/site/login'));
        }

        $filterChain->run();
    }

    public function actionCreate() {
        $cheque = new ChequeTransaction();

        if (isset($_GET['id']))
            $cheque->copyFromDb($_GET['id']);

        if ($cheque->header->isNewRecord) {
            $cheque->header->is_non_tax = intval(isset($_GET['nt']));
            $cheque->header->number = CodeNumber::make($cheque->header, 'number', ($cheque->header->is_non_tax) ? 'NCHQ' : 'CHQ', ($cheque->header->is_non_tax) ? true : false);
        }

        $cheque->header->admin_id = Yii::app()->user->id;
        $this->loadState($cheque);

        $receiptHeader = new ReceiptHeader('search');
        $receiptHeader->unsetAttributes();  // clear any default values
        if (isset($_GET['ReceiptHeader']))
            $receiptHeader->attributes = $_GET['ReceiptHeader'];

        $error = false;

        if (isset($_POST['Submit']) && IdempotentManager::check()) {
            
            if ($cheque->header->isNewRecord) {
                $cheque->header->is_non_tax = intval(isset($_GET['nt']));
                $cheque->header->number = CodeNumber::make($cheque->header, 'number', ($cheque->header->is_non_tax) ? 'NCHQ' : 'CHQ', ($cheque->header->is_non_tax) ? true : false);
            }

            $dbTransaction = CActiveRecord::$db->beginTransaction();
            try {
                if ($cheque->validate() && IdempotentManager::build()->save() && $cheque->save(false)) {
                    $dbTransaction->commit();
                    Yii::app()->session['ChequeMemoAllowed'] = true;
                    $this->redirect(array('view', 'id' => $cheque->header->id));
                } else {
                    $dbTransaction->rollback();
                    $error = true;
                }
            } catch (Exception $e) {
                $dbTransaction->rollback();
                throw new CHttpException($e->getCode(), $e->getMessage());
            }
        }

        $this->render('create', array(
            'cheque' => $cheque,
            'receiptHeader' => $receiptHeader,
            'error' => $error,
        ));
    }

    public function actionView($id) {
        $cheque = Cheque::model()->findByPk($id);

        $this->render('view', array(
            'cheque' => $cheque,
        ));
    }

    public function actionMemo($id) {
        if (!(Yii::app()->user->checkAccess('administrator'))) {
            if (!(isset(Yii::app()->session['ChequeMemoAllowed']) && Yii::app()->session['ChequeMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('ChequeMemoAllowed');

        $cheque = Cheque::model()->findByPk($id);

        $chequeCustomer = ($cheque->is_non_tax) ? $cheque->receiptHeader->customer->name : $cheque->receiptHeader->customer->company;
        $chequeHeaderText = ($cheque->is_non_tax) ? '' : 'PT. Galatech';
        $this->render('memo', array(
            'cheque' => $cheque,
            'chequeCustomer' => $chequeCustomer,
            'chequeHeaderText' => $chequeHeaderText,
        ));
    }

    public function actionDelete($id) {
        if (Yii::app()->request->isPostRequest) {
            $cheque = Cheque::model()->resetScope()->findByPk($id);
            if ($cheque !== null) {
                $cheque->is_inactive = !$cheque->is_inactive;
                $cheque->update(array('is_inactive'));
            }

            if (!isset($_GET['ajax']))
                $this->redirect(isset($_POST['returnUrl']) ? $_POST['returnUrl'] : array('admin'));
        } else
            throw new CHttpException(400, 'Invalid request. Please do not repeat this request again.');
    }

    public function actionAdmin() {
        $cheque = new Cheque('search');
        $cheque->unsetAttributes();

        if (isset($_GET['Cheque']))
            $cheque->attributes = $_GET['Cheque'];

        $customerId = (isset($_GET['CustomerId'])) ? $_GET['CustomerId'] : '';

        $dataProvider = $cheque->search();
        $dataProvider->criteria->join = "INNER JOIN tblgt_receipt_header receiptHeader ON (t.receipt_header_id = receiptHeader.id) AND (receiptHeader.is_inactive = 0)";
        $dataProvider->criteria->compare('receiptHeader.customer_id', $customerId);

        $this->render('admin', array(
            'cheque' => $cheque,
            'dataProvider' => $dataProvider,
            'customerId' => $customerId,
        ));
    }

    public function actionReport() {
        $cheque = new Cheque('search');
        $cheque->unsetAttributes();
        if (isset($_GET['Cheque']))
            $cheque->attributes = $_GET['Cheque'];

        $startDate = (isset($_GET['StartDate'])) ? $_GET['StartDate'] : '';
        $endDate = (isset($_GET['EndDate'])) ? $_GET['EndDate'] : '';
        $pageSize = (isset($_GET['PageSize'])) ? $_GET['PageSize'] : '';
        $currentPage = (isset($_GET['page'])) ? $_GET['page'] : '';
        $currentSort = (isset($_GET['sort'])) ? $_GET['sort'] : '';
        $customerId = (isset($_GET['CustomerId'])) ? $_GET['CustomerId'] : '';

        $dataProvider = $cheque->search();
        $dataProvider->criteria->compare('receiptHeader.customer_id', $customerId);
        $dataProvider->criteria->join = "INNER JOIN " . ReceiptHeader::model()->tableName() . " ReceiptHeader ON ReceiptHeader.id = t.receipt_header_id INNER JOIN " . Customer::model()->tableName() . " customer ON ReceiptHeader.customer_id = customer.id";

        $page = array('size' => $pageSize, 'current' => $currentPage);
        $date = array('attribute' => 'receive_date', 'start' => $startDate, 'end' => $endDate);

        $sort = new CSort(get_class($cheque));
        $sort->attributes = array('receive_date', 'customer.name');

        $dataProvider = ReportHelper::finalizeDataProvider($dataProvider, $page, $sort, $date);

        $this->render('report', array(
            'cheque' => $cheque,
            'dataProvider' => $dataProvider,
            'startDate' => $startDate,
            'endDate' => $endDate,
            'sort' => $sort,
            'currentSort' => $currentSort,
            'customerId' => $customerId,
        ));
    }

    public function actionAmountAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $cheque = new ChequeTransaction();

            if (!empty($id))
                $cheque->copyFromDb($id);

            $this->loadState($cheque);

            $amount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($cheque->header, 'amount')));

            echo CJSON::encode(array(
                'amount' => $amount,
            ));
        }
    }

    public function actionreceiptAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $cheque = new ChequeTransaction();

            if (!empty($id))
                $cheque->copyFromDb($id);

            $this->loadState($cheque);

            $object = array(
                'receipt_header_number' => $cheque->header->receiptHeader->number,
                'receipt_header_date' => $cheque->header->receiptHeader->date,
                'receipt_header_customer' => $cheque->header->receiptHeader->customer->company,
            );

            echo CJSON::encode($object);
        }
    }

    protected function loadState(&$cheque) {
        if (isset($_POST['Cheque'])) {
            $cheque->header->attributes = $_POST['Cheque'];
        }
    }
}
