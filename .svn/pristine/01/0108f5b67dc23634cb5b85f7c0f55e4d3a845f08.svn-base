<?php

class Transfer extends CComponent
{
	public $header;
	public $details;

	public function __construct()
	{
		$this->header = new TransferHeader();
		$this->details = array();
	}
       
	public function addProduct($id)
	{
		$product = Product::model()->findByPk($id);

		if ($product !== null)
		{
			$exist = false;
			foreach ($this->details as $i => $detail)
			{
				if ($product->id === $detail->product_id)
				{
					$exist = true;
					break;
				}
			}

			if ($exist)
				$this->details[$i]->quantity++;
			else
			{
				$detail = new TransferDetail();
				$detail->product_id = $product->id;
				$this->details[] = $detail;
			}
		}
	}

	public function removeProductAt($index)
	{
		array_splice($this->details, $index, 1);
	}

	public function validate()
	{
		$valid = $this->header->validate();

		if (count($this->details) > 0)
		{
			foreach ($this->details as $detail)
			{
				$fields = array('quantity', 'unit_price', 'product_id');
				$valid = $detail->validate($fields) && $valid;
			}
		}
		else
			$valid = false;

		return $valid;
	}

	public function insert()
	{
		$valid = $this->header->insert();

		Inventory::model()->DeleteAllByAttributes(array('transaction_number' => $this->header->number));
		
		foreach ($this->details as $detail)
		{
			$detail->transfer_header_id = $this->header->id;
			$valid = $detail->insert() && $valid;

			if ((int)$detail->is_inactive === 0)
			{
				$inventoryFrom = new Inventory();
				$inventoryFrom->date = $this->header->date;
				$inventoryFrom->transaction_number = $this->header->number;
				$inventoryFrom->transaction_type = 4;
				$inventoryFrom->transaction_subject = $this->header->warehouseIdFrom->name;
				$inventoryFrom->quantity_out = $detail->quantity;
				$inventoryFrom->product_id = $detail->product_id;
				$inventoryFrom->warehouse_id = $this->header->warehouse_id_from;
				$inventoryFrom->admin_id = $this->header->admin_id;

				$valid = $inventoryFrom->insert() && $valid;

				$inventoryTo = new Inventory();
				$inventoryTo->transaction_number = $this->header->number;
				$inventoryTo->transaction_type = 4;
				$inventoryTo->transaction_subject = $this->header->warehouseIdTo->name;
				$inventoryTo->product_id = $detail->product_id;
				$inventoryTo->warehouse_id = $this->header->warehouse_id_to;
				$inventoryTo->admin_id = $this->header->admin_id;
				$inventoryTo->date = $this->header->date;
				$inventoryTo->quantity_in = $detail->quantity;

				$valid = $inventoryTo->save() && $valid;
			}
		}

		return $valid;
	}
}
