						<li><?php echo CHtml::link('Penerimaan Barang per Item (Summary)', array('/transaction/receiveItem/report')); ?><br/><br/></li>
					<?php endif; ?>
						
				</ul>
        </fieldset>
        
        <fieldset id="warehouse-fieldset">
                <legend>Gudang</legend>
