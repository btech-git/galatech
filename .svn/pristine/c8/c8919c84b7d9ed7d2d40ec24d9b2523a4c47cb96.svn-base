@media screen
{
        .hide
        {
                display: block;
        }
}
@media print
{
        .hide
        {
                display: none;
        }
        #page
        {
                border: none;
        }
}

.divtable
{
        display: table;
        width: 100%;
}

.divtablerow
{
        display: table-row;
}

.divtablecell
{
        display: table-cell;
}

.info
{
        padding: 2px;
}

div#memoheader, div.memonote, div.memosig, table.memo
{
        font-size: 10px;
		font-family: Arial,Helvetica,sans-serif;
}

div#memoheader
{
        font-weight: bold;
        text-align: center;
}

div.memonote
{
        width: 80%;
        margin: 0 auto;
font-size: 12px;
}

div.memosig
{
        margin: 0 auto;
        text-align: center;
		font-size: 12px;
}

table.memo, table.memo tr#theader th, table.memo tr.titems td
{
        border-left: 1px solid;
        border-right: 1px solid;
		vertical-align:text-top;
}

table.memo
{
        width: 100%;
        margin-left: auto;
        margin-right: auto;
        border-spacing: 0pt;
        border-top: 2px solid;
        border-bottom: 2px solid;
font-size: 12px;
}

table.memo tr#theader th
{
        text-align: center;
        border-bottom: 2px solid;
}