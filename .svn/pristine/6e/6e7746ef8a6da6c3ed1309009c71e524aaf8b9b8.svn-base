<?php

class PurchaseItemsReport extends CComponent {

    public $dataProvider;

    public function __construct($dataProvider) {
        $this->dataProvider = $dataProvider;
    }

    public function setupLoading() {
        
    }

    public function setupPaging($pageSize, $currentPage) {
        $pageSize = (empty($pageSize)) ? 10 : $pageSize;
        $pageSize = ($pageSize <= 0) ? 1 : $pageSize;
        $this->dataProvider->pagination->pageSize = $pageSize;

        $currentPage = (empty($currentPage)) ? 0 : $currentPage - 1;
        $this->dataProvider->pagination->currentPage = $currentPage;
    }

    public function setupSorting() {
        $this->dataProvider->sort->defaultOrder = 't.name ASC';
        $this->dataProvider->criteria->order = $this->dataProvider->sort->orderBy;
    }

    public function setupFilter($startDate, $endDate, $productName, $productCategory) {
        
        $this->dataProvider->criteria->addCondition("EXISTS (
            SELECT d.id
            FROM " . PurchaseDetail::model()->tableName() . " d 
            INNER JOIN " . PurchaseHeader::model()->tableName() . " h ON h.id = d.purchase_header_id
            WHERE d.product_id = t.id AND h.date BETWEEN :start_date AND :end_date
        )");
        $this->dataProvider->criteria->params[':start_date'] = $startDate;
        $this->dataProvider->criteria->params[':end_date'] = $endDate;
        $this->dataProvider->criteria->compare('t.name', $productName, true);
        $this->dataProvider->criteria->compare('t.category_id', $productCategory);
    }
}
