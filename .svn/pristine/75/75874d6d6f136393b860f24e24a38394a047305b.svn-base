            if (!isset($_POST['SalesPaymentDetailRev']))
                $salesPayment->details = array();

            $this->loadState($salesPayment);

            $object = array(
                'customer_id' => $salesPayment->header->customer->company,
                'customer_name' => $salesPayment->header->customer->name,
                'customer_address' => $salesPayment->header->customer->address,
            );
            echo CJSON::encode($object);
        }
    }

    public function actionAddReceiptAjax($id, $nt) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesPayment = new SalesPayment();

//            if (!empty($id))
//                $salesPayment->copyFromDb($id);

            if ($salesPayment->header->isNewRecord)
                $salesPayment->header->is_non_tax = intval($nt);

            $this->loadState($salesPayment);

            $salePaymentAccountSecondary = 'id IN (3, 48, 1, 215, 288, 370, 160, 161, 467)';
            $salePaymentAccountPrimary = 'id IN (47, 2, 214, 260, 160, 161, 463)';

            if (isset($_POST['ReceiptHeaderId']))
                $salesPayment->addReceipt($_POST['ReceiptHeaderId']);

            $this->renderPartial('_detail', array(
                'salesPayment' => $salesPayment,
                'salePaymentAccountSecondary' => $salePaymentAccountSecondary,
                'salePaymentAccountPrimary' => $salePaymentAccountPrimary,
                'error' => false,
            ));
        }
    }

