    protected function loadState($salesPayment) {
        if (isset($_POST['SalesPaymentHeaderRev'])) {
            $salesPayment->header->attributes = $_POST['SalesPaymentHeaderRev'];
        }
        if (isset($_POST['SalesPaymentDetailRev'])) {
            foreach ($_POST['SalesPaymentDetailRev'] as $i => $item) {

                if (isset($salesPayment->details[$i]))
                    $salesPayment->details[$i]->attributes = $item;
                else {
                    $detail = new SalesPaymentDetailRev();
                    $detail->attributes = $item;
                    $salesPayment->details[] = $detail;
                }
            }
            if (count($_POST['SalesPaymentDetailRev']) < count($salesPayment->details))
                array_splice($salesPayment->details, $i + 1);
        }
        if (isset($_POST['SalesPaymentExtra'])) {
            foreach ($_POST['SalesPaymentExtra'] as $i => $item) {
                if (isset($salesPayment->extras[$i]))
                    $salesPayment->extras[$i]->attributes = $item;
                else {
                    $extras = new SalesPaymentExtra();
                    $extras->attributes = $item;
                    $salesPayment->extras[] = $extras;
                }
            }
            if (count($_POST['SalesPaymentExtra']) < count($salesPayment->extras))
                array_splice($salesPayment->extras, $i + 1);
        }
    }
