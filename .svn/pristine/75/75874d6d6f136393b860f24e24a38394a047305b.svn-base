<?php

class SalesPaymentController extends Controller {

    public function filters() {
        return array(
            'access',
        );
    }

    public function filterAccess($filterChain) {
        $taxCreateValid = Yii::app()->user->checkAccess('tSalesPaymentCreate') || Yii::app()->user->checkAccess('tsSalesPaymentCreate');
        $nonTaxCreateValid = Yii::app()->user->checkAccess('ntSalesPaymentCreate');
        $taxEditValid = Yii::app()->user->checkAccess('tSalesPaymentEdit') || Yii::app()->user->checkAccess('tsSalesPaymentEdit');
        $nonTaxEditValid = Yii::app()->user->checkAccess('ntSalesPaymentEdit');

        if ($filterChain->action->id === 'create') {
            $params = $filterChain->controller->actionParams;

            if (isset($params['id'])) {
                if (!($taxEditValid || $nonTaxEditValid))
                    $this->redirect(array('/site/login'));
            } else {
                if (isset($params['nt'])) {
                    if (!$nonTaxCreateValid)
                        $this->redirect(array('/site/login'));
                } else {
                    if (!$taxCreateValid)
                        $this->redirect(array('/site/login'));
                }
            }
        }
        if ($filterChain->action->id === 'addAccountAjax' || $filterChain->action->id === 'receiptAjaxData' || $filterChain->action->id === 'removePaymentAjax' || $filterChain->action->id === 'summaryAjaxData' || $filterChain->action->id === 'view') {
            if (!($taxCreateValid || $nonTaxCreateValid || $taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'delete' || $filterChain->action->id === 'admin') {
            if (!($taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'report') {
            if (!(Yii::app()->user->checkAccess('ntSalesPaymentReport') || Yii::app()->user->checkAccess('tSalesPaymentReport') || Yii::app()->user->checkAccess('tsSalesPaymentReport')))
                $this->redirect(array('/site/login'));
        }

        $filterChain->run();
    }

    public function actionCreate() {
        $salesPayment = new SalesPayment();

//        if (isset($_GET['id'])) {
//            $salesPayment->copyFromDb($_GET['id']);
//        }

        if ($salesPayment->header->isNewRecord) {
            $salesPayment->header->is_non_tax = intval(isset($_GET['nt']));
            $salesPayment->header->number = CodeNumber::make($salesPayment->header, 'number', ($salesPayment->header->is_non_tax) ? 'NSPY' : 'SPY', ($salesPayment->header->is_non_tax) ? true : false);
        }

        $salePaymentAccountSecondary = 'id IN (3, 48, 1, 215, 288, 370, 160, 161, 467)';
        $salePaymentAccountPrimary = 'id IN (47, 2, 214, 260, 160, 161, 463)';

        $salesPayment->header->admin_id = Yii::app()->user->id;
        $this->loadState($salesPayment);

        $customer = new Customer('search');
        $customer->unsetAttributes();  // clear any default values
        if (isset($_GET['Customer'])) {
            $customer->attributes = $_GET['Customer'];
        }

        $receiptHeader = new ReceiptHeader('search');
        $receiptHeader->unsetAttributes();  // clear any default values
        if (isset($_GET['ReceiptHeader'])) {
            $receiptHeader->attributes = $_GET['ReceiptHeader'];
        }

        $account = new Account('search');
        $account->unsetAttributes();
        if (isset($_GET['Account'])) {
            $account->attributes = $_GET['Account'];
        }

        $error = false;

        if (isset($_POST['Submit']) && IdempotentManager::check()) {
            if ($salesPayment->header->isNewRecord) {
                $salesPayment->header->is_non_tax = intval(isset($_GET['nt']));
                $salesPayment->header->number = CodeNumber::make($salesPayment->header, 'number', ($salesPayment->header->is_non_tax) ? 'NSPY' : 'SPY', ($salesPayment->header->is_non_tax) ? true : false);
            }

            $dbTransaction = CActiveRecord::$db->beginTransaction();
            try {
                if ($salesPayment->validate() && IdempotentManager::build()->save() && $salesPayment->save(false)) {
                    $dbTransaction->commit();
                    Yii::app()->session['SalesPaymentMemoAllowed'] = true;
                    $this->redirect(array('view', 'id' => $salesPayment->header->id));
                } else {
                    $dbTransaction->rollback();
                    $error = true;
                }
            } catch (Exception $e) {
                $dbTransaction->rollback();
                throw new CHttpException($e->getCode(), $e->getMessage());
            }
        }

        $this->render('create', array(
            'salesPayment' => $salesPayment,
            'customer' => $customer,
            'receiptHeader' => $receiptHeader,
            'account' => $account,
            'salePaymentAccountSecondary' => $salePaymentAccountSecondary,
            'salePaymentAccountPrimary' => $salePaymentAccountPrimary,
            'error' => $error,
        ));
    }

    public function actionView($id) {
        $salesPayment = SalesPaymentHeaderRev::model()->findByPk($id);

        $this->render('view', array(
            'salesPayment' => $salesPayment,
        ));
    }

    public function actionMemo($id) {
        if (!(Yii::app()->user->checkAccess('administrator'))) {
            if (!(isset(Yii::app()->session['SalesPaymentMemoAllowed']) && Yii::app()->session['SalesPaymentMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('SalesPaymentMemoAllowed');

        $salesPayment = SalesPaymentHeaderRev::model()->findByPk($id);

        $salesPaymentCustomer = ($salesPayment->is_non_tax) ? $salesPayment->customer->name : $salesPayment->customer->company;
        $salesPaymentHeaderText = ($salesPayment->is_non_tax) ? '' : 'PT. GALATECH JAYA ABADI';

        $this->render('memo', array(
            'salesPayment' => $salesPayment,
            'salesPaymentCustomer' => $salesPaymentCustomer,
            'salesPaymentHeaderText' => $salesPaymentHeaderText,
        ));
    }

    public function actionDelete($id) {
        if (Yii::app()->request->isPostRequest) {
            $salesPayment = SalesPaymentHeaderRev::model()->resetScope()->findByPk($id);
            if ($salesPayment !== null) {
                $salesPayment->is_inactive = !$salesPayment->is_inactive;
                $salesPayment->update(array('is_inactive'));
            }

            if (!isset($_GET['ajax']))
                $this->redirect(isset($_POST['returnUrl']) ? $_POST['returnUrl'] : array('admin'));
        } else
            throw new CHttpException(400, 'Invalid request. Please do not repeat this request again.');
    }

