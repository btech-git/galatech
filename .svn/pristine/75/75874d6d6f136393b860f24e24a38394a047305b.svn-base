    public function actionSummaryAjaxData($id, $index) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesPayment = new SalesPayment();

//            if (!empty($id))
//                $salesPayment->copyFromDb($id);

            if (!isset($_POST['SalesPaymentDetailRev']))
                $salesPayment->details = array();

            $this->loadState($salesPayment);

            $amount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($salesPayment->details[$index], 'amount')));
            $total = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($salesPayment, 'totalInvoice')));
            $amountPaid = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($salesPayment, 'amountPaid')));
            $totalPayment = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($salesPayment, 'totalPayment')));

            echo CJSON::encode(array(
                'amount' => $amount,
                'total' => $total,
                'amountPaid' => $amountPaid,
                'totalPayment' => $totalPayment,
            ));
        }
    }

