    public function actionReport() {
        $salesPaymentHeader = new SalesPaymentHeaderRev('search');
        $salesPaymentHeader->unsetAttributes();
        if (isset($_GET['SalesPaymentHeaderRev']))
            $salesPaymentHeader->attributes = $_GET['SalesPaymentHeaderRev'];

        $startDate = (isset($_GET['StartDate'])) ? $_GET['StartDate'] : '';
        $endDate = (isset($_GET['EndDate'])) ? $_GET['EndDate'] : '';
        $pageSize = (isset($_GET['PageSize'])) ? $_GET['PageSize'] : '';
        $currentPage = (isset($_GET['page'])) ? $_GET['page'] : '';
        $currentSort = (isset($_GET['sort'])) ? $_GET['sort'] : '';

        $customerId = (isset($_GET['CustomerId'])) ? $_GET['CustomerId'] : '';

        $dataProvider = $salesPaymentHeader->search();
//		$dataProvider->criteria->compare('receiptHeader.customer_id', $customerId);
//		$dataProvider->criteria->join = "INNER JOIN " . ReceiptHeader::model()->tableName() . " ReceiptHeader ON ReceiptHeader.id = t.receipt_header_id INNER JOIN " . Customer::model()->tableName() . " customer ON ReceiptHeader.customer_id = customer.id";

        $page = array('size' => $pageSize, 'current' => $currentPage);
        $date = array('attribute' => 't.date', 'start' => $startDate, 'end' => $endDate);

        $sort = new CSort(get_class($salesPaymentHeader));
        $sort->attributes = array('t.date', 'customer_id');

        $dataProvider = ReportHelper::finalizeDataProvider($dataProvider, $page, $sort, $date);

        $this->render('report', array(
            'salesPaymentHeader' => $salesPaymentHeader,
            'dataProvider' => $dataProvider,
            'startDate' => $startDate,
            'endDate' => $endDate,
            'sort' => $sort,
            'currentSort' => $currentSort,
            'customerId' => $customerId,
        ));
    }

    public function actionReceiptAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesPayment = new SalesPayment();

//            if (!empty($id))
//                $salesPayment->copyFromDb($id);

            if (!isset($_POST['SalesPaymentDetail']))
                $salesPayment->details = array();

            $this->loadState($salesPayment);

            $object = array(
                'receipt_header_number' => $salesPayment->header->receiptHeader->number,
                'receipt_header_date' => Yii::app()->dateFormatter->format("d MMMM yyyy", $salesPayment->header->receiptHeader->date),
                'receipt_header_customer' => $salesPayment->header->receiptHeader->customer->company,
            );

            echo CJSON::encode($object);
        }
    }

    public function actionCustomerAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesPayment = new SalesPayment();

//            if (!empty($id))
