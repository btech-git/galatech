<?php

class SqlViewGenerator extends CComponent
{
	public static function count($view)
	{
		$sql = "SELECT COUNT(*) FROM ({$view}) v";

		return $sql;
	}

	public static function receiveStock()
	{
		$sql = "SELECT COALESCE(SUM(d.quantity), 0) AS quantity 
				FROM ".ReceiveHeader::model()->tableName()." h 
				INNER JOIN ".ReceiveDetail::model()->tableName()." d ON h.id = d.receive_header_id";

		return $sql;
	}

	public static function purchaseReturnStock()
	{
		$sql = "SELECT COALESCE(SUM(d.quantity), 0) AS quantity 
				FROM ".PurchaseReturnHeader::model()->tableName()." h 
				INNER JOIN ".PurchaseReturnDetail::model()->tableName()." d ON h.id = d.purchase_return_header_id";

		return $sql;
	}

	public static function adjustmentStock()
	{
		$sql = "SELECT COALESCE(SUM(d.quantity_adjustment - d.quantity_current), 0) AS quantity 
				FROM ".AdjustmentHeader::model()->tableName()." h 
				INNER JOIN ".AdjustmentDetail::model()->tableName()." d ON h.id = d.adjustment_header_id";

		return $sql;
	}

	public static function transferStock()
	{
		$sql = "SELECT COALESCE(SUM(d.quantity), 0) AS quantity 
				FROM ".TransferHeader::model()->tableName()." h 
				INNER JOIN ".TransferDetail::model()->tableName()." d ON h.id = d.transfer_header_id";

		return $sql;
	}

	public static function deliveryStock()
	{
		$sql = "SELECT COALESCE(SUM(d.quantity), 0) AS quantity 
				FROM ".DeliveryHeader::model()->tableName()." h 
				INNER JOIN ".DeliveryDetail::model()->tableName()." d ON h.id = d.delivery_header_id";

		return $sql;
	}

	public static function salesReturnStock()
	{
		$sql = "SELECT COALESCE(SUM(d.quantity), 0) AS quantity 
				FROM ".SalesReturnHeader::model()->tableName()." h 
				INNER JOIN ".SalesReturnDetail::model()->tableName()." d ON h.id = d.sales_return_header_id";

		return $sql;
	}

	public static function globalStock()
	{
		$sql = "SELECT p.id, COALESCE(receive.quantity, 0) - COALESCE(purchase_return.quantity, 0) + COALESCE(adjustment.quantity, 0) - COALESCE(transfer_from.quantity, 0) + COALESCE(transfer_to.quantity, 0) - COALESCE(delivery.quantity, 0) + COALESCE(sales_return.quantity, 0) AS current_stock
				FROM tblgt_product p
				LEFT OUTER JOIN
				(
					SELECT d.product_id, COALESCE(SUM(d.quantity), 0) AS quantity 
					FROM tblgt_receive_header h 
					INNER JOIN tblgt_receive_detail d ON h.id = d.receive_header_id
					WHERE h.is_inactive = 0 AND d.is_inactive = 0
					GROUP BY d.product_id
				) receive
				ON p.id = receive.product_id
				LEFT OUTER JOIN
				(
					SELECT d.product_id, COALESCE(SUM(d.quantity), 0) AS quantity 
					FROM tblgt_purchase_return_header h 
					INNER JOIN tblgt_purchase_return_detail d ON h.id = d.purchase_return_header_id
					WHERE h.is_inactive = 0 AND d.is_inactive = 0
					GROUP BY d.product_id
				) purchase_return
				ON p.id = purchase_return.product_id
				LEFT OUTER JOIN
				(
					SELECT d.product_id, COALESCE(SUM(d.quantity_adjustment - d.quantity_current), 0) AS quantity 
					FROM tblgt_adjustment_header h 
					INNER JOIN tblgt_adjustment_detail d ON h.id = d.adjustment_header_id
					WHERE h.is_inactive = 0 AND d.is_inactive = 0
					GROUP BY d.product_id
				) adjustment
				ON p.id = adjustment.product_id
				LEFT OUTER JOIN
				(
					SELECT d.product_id, COALESCE(SUM(d.quantity), 0) AS quantity 
					FROM tblgt_transfer_header h 
					INNER JOIN tblgt_transfer_detail d ON h.id = d.transfer_header_id
					WHERE h.is_inactive = 0 AND d.is_inactive = 0
					GROUP BY d.product_id
				) transfer_from
				ON p.id = transfer_from.product_id
				LEFT OUTER JOIN
				(
					SELECT d.product_id, COALESCE(SUM(d.quantity), 0) AS quantity 
					FROM tblgt_transfer_header h 
					INNER JOIN tblgt_transfer_detail d ON h.id = d.transfer_header_id
					WHERE h.is_inactive = 0 AND d.is_inactive = 0
					GROUP BY d.product_id
				) transfer_to
				ON p.id = transfer_to.product_id
				LEFT OUTER JOIN
				(
					SELECT d.product_id, COALESCE(SUM(d.quantity), 0) AS quantity 
					FROM tblgt_delivery_header h 
					INNER JOIN tblgt_delivery_detail d ON h.id = d.delivery_header_id
					WHERE h.is_inactive = 0 AND d.is_inactive = 0
					GROUP BY d.product_id
				) delivery
				ON p.id = delivery.product_id
				LEFT OUTER JOIN
				(
					SELECT d.product_id, COALESCE(SUM(d.quantity), 0) AS quantity 
					FROM tblgt_sales_return_header h 
					INNER JOIN tblgt_sales_return_detail d ON h.id = d.sales_return_header_id
					WHERE h.is_inactive = 0 AND d.is_inactive = 0
					GROUP BY d.product_id
				) sales_return
				ON p.id = sales_return.product_id";

		return $sql;
	}

	public static function excelCategorySize()
	{
		$sql = "SELECT DISTINCT category_id, size FROM tblgt_product 
				WHERE is_inactive = 0 ORDER BY category_id, size";

		return $sql;
	}

	public static function excelGlobalStock()
	{
		$sql = "SELECT p.category_id, p.name, p.size, c.name AS category_name, ps.current_stock
				FROM tblgt_product p INNER JOIN tblgt_category c ON p.category_id = c.id
				INNER JOIN (".SqlViewGenerator::globalStock().") ps
				ON p.id = ps.id
				WHERE p.is_inactive = 0 AND c.is_inactive = 0
				ORDER BY p.category_id, p.name, p.size";

		return $sql;
	}
/*
    SELECT h.number, h.date, h.account_id, d.account_id AS detail_account_id, 0 AS debit, d.amount AS credit, 'd' AS type
    FROM " . DepositHeader::model()->tableName() . " h 
    INNER JOIN " . DepositDetail::model()->tableName() . " d ON h.id = d.deposit_header_id
    WHERE h.is_inactive = 0 AND d.is_inactive = 0
    UNION ALL
    SELECT h.number, h.date, h.account_id, d.account_id AS detail_account_id, 0 AS debit, d.amount AS credit, 'e' AS type
    FROM " . ExpenseHeader::model()->tableName() . " h 
    INNER JOIN " . ExpenseDetail::model()->tableName() . " d ON h.id = d.expense_header_id
    WHERE h.is_inactive = 0 AND d.is_inactive = 0
    UNION ALL*/
	public static function balance()
	{
		$sql = "SELECT h.number, h.date, h.account_id, d.account_id AS detail_account_id, d.amount AS debit, 0 AS credit, 'd' AS type
				FROM " . DepositHeader::model()->tableName() . " h 
				INNER JOIN " . DepositDetail::model()->tableName() . " d ON h.id = d.deposit_header_id
				WHERE h.is_inactive = 0 AND d.is_inactive = 0
				UNION ALL
				SELECT h.number, h.date, h.account_id, d.account_id AS detail_account_id, d.amount AS debit, 0 AS credit, 'e' AS type
				FROM " . ExpenseHeader::model()->tableName() . " h 
				INNER JOIN " . ExpenseDetail::model()->tableName() . " d ON h.id = d.expense_header_id
				WHERE h.is_inactive = 0 AND d.is_inactive = 0
				UNION ALL
				SELECT h.number, h.date, d.account_id, d.account_id AS detail_account_id, d.debit AS debit, d.credit AS credit, 'o' AS type
				FROM " . JournalVoucherHeader::model()->tableName() . " h 
				INNER JOIN " . JournalVoucherDetail::model()->tableName() . " d ON h.id = d.journal_voucher_header_id
				WHERE h.is_inactive = 0 AND d.is_inactive = 0
				UNION ALL
				SELECT h.number, h.date, d.account_id, s.account_id AS detail_account_id, 0 AS debit, d.amount AS credit, 'o' AS type
				FROM " . PurchasePaymentHeaderRev::model()->tableName() . " h 
				INNER JOIN " . PurchasePaymentDetailRev::model()->tableName() . " d ON h.id = d.purchase_payment_header_rev_id
				INNER JOIN " . PurchaseReceiptHeader::model()->tableName() . "  pr ON pr.id = d.purchase_receipt_header_id
				INNER JOIN " . Supplier::model()->tableName() . " s ON s.id = pr.supplier_id 
				WHERE h.is_inactive = 0 AND d.is_inactive = 0 AND pr.is_inactive = 0
				UNION ALL
				SELECT h.number, h.date, d.account_id, c.account_id AS detail_account_id, d.amount AS debit, 0 AS credit, 'o' AS type
				FROM " . SalesPaymentHeaderRev::model()->tableName() . " h 
				INNER JOIN " . SalesPaymentDetailRev::model()->tableName() . " d ON h.id = d.sales_payment_header_rev_id
				INNER JOIN " . ReceiptHeader::model()->tableName() . " r ON r.id = d.receipt_header_id
				INNER JOIN " . Customer::model()->tableName() . " c ON c.id = r.customer_id
				WHERE h.is_inactive = 0 AND d.is_inactive = 0 AND r.is_inactive = 0
				UNION ALL
				SELECT sd.number, sd.date, sd.account_id, c.account_id AS detail_account_id, (sd.amount * ( 1 + (sd.tax / 100))) AS debit, 0 AS credit, 'o' AS type
				FROM " . SalesDownpayment::model()->tableName() . " sd	
				INNER JOIN " . Customer::model()->tableName() . " c ON c.id = sd.customer_id
				WHERE sd.is_inactive = 0";
		
		return $sql;
	}
	
