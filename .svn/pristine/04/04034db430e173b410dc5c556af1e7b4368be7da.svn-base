			'value' => '$data->warehouseIdTo->name',
		),
		array(
			'name' => 'admin_id',
			'filter' => CHtml::listData(Admin::model()->findAll(), 'id', 'name'),
			'value' => '$data->admin->name',
		),
		array(
			'class'=>'CButtonColumn',
			'template' => '{view}{delete}'
		),
	),
)); ?>

