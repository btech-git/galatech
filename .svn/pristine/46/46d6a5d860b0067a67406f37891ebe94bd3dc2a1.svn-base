<?php

class PurchaseChequeController extends Controller {

    public function filters() {
        return array(
            'access',
        );
    }

    public function filterAccess($filterChain) {
        $taxCreateValid = Yii::app()->user->checkAccess('tAccountingCreate') || Yii::app()->user->checkAccess('tsAccountingCreate');
        $nonTaxCreateValid = Yii::app()->user->checkAccess('ntAccountingCreate');
        $taxEditValid = Yii::app()->user->checkAccess('tAccountingEdit') || Yii::app()->user->checkAccess('tsAccountingEdit');
        $nonTaxEditValid = Yii::app()->user->checkAccess('ntAccountingEdit');

        if ($filterChain->action->id === 'create') {
            $params = $filterChain->controller->actionParams;

            if (isset($params['id'])) {
                if (!($taxEditValid || $nonTaxEditValid))
                    $this->redirect(array('/site/login'));
            } else {
                if (isset($params['nt'])) {
                    if (!$nonTaxCreateValid)
                        $this->redirect(array('/site/login'));
                } else {
                    if (!$taxCreateValid)
                        $this->redirect(array('/site/login'));
                }
            }
        }
        if ($filterChain->action->id === 'amountAjaxdata' || $filterChain->action->id === 'purchaseReceiptAjaxdata' || $filterChain->action->id === 'memo' || $filterChain->action->id === 'view') {
            if (!($taxCreateValid || $nonTaxCreateValid || $taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'delete' || $filterChain->action->id === 'admin') {
            if (!($taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'report') {
            if (!(Yii::app()->user->checkAccess('ntAccountingReport') || Yii::app()->user->checkAccess('tAccountingReport') || Yii::app()->user->checkAccess('tsAccountingReport')))
                $this->redirect(array('/site/login'));
        }

        $filterChain->run();
    }

    public function actionCreate() {
        $purchaseCheque = new PurchaseCheque();

        if (isset($_GET['id']))
            $purchaseCheque->copyFromDb($_GET['id']);

        if ($purchaseCheque->header->isNewRecord) {
            $purchaseCheque->header->is_non_tax = intval(isset($_GET['nt']));
            $purchaseCheque->header->number = CodeNumber::make($purchaseCheque->header, 'number', ($purchaseCheque->header->is_non_tax) ? 'NCGK' : 'CGK', ($purchaseCheque->header->is_non_tax) ? true : false);
        }

        $purchaseChequeAccountCategorySecondary = 'id IN(1, 48, 288, 160, 161, 370, 3, 467)';
        $purchaseChequeAccountCategoryPrimary = 'id IN (2, 47, 260, 160, 161, 463)';

        $purchaseReceiptHeader = new PurchaseReceiptHeader('search');
        $purchaseReceiptHeader->unsetAttributes();  // clear any default values
        if (isset($_GET['PurchaseReceiptHeader']))
            $purchaseReceiptHeader->attributes = $_GET['PurchaseReceiptHeader'];

        $supplier = new Supplier('search');
        $supplier->unsetAttributes();  // clear any default values
        if (isset($_GET['Supplier']))
            $supplier->attributes = $_GET['Supplier'];

        $purchaseCheque->header->admin_id = Yii::app()->user->id;
        $this->loadState($purchaseCheque);

        $error = false;

        if (isset($_POST['Submit']) && IdempotentManager::check()) {
            $dbTransaction = CActiveRecord::$db->beginTransaction();
            try {
                if ($purchaseCheque->validate() && IdempotentManager::build()->save() && $purchaseCheque->save(false)) {
                    $dbTransaction->commit();
                    Yii::app()->session['PurchaseChequeMemoAllowed'] = true;
                    $this->redirect(array('view', 'id' => $purchaseCheque->header->id));
                } else {
                    $dbTransaction->rollback();
                    $error = true;
                }
            } catch (Exception $e) {
                $dbTransaction->rollback();
                throw new CHttpException($e->getCode(), $e->getMessage());
            }
        }

        $this->render('create', array(
            'purchaseCheque' => $purchaseCheque,
            'purchaseReceiptHeader' => $purchaseReceiptHeader,
            'purchaseChequeAccountCategorySecondary' => $purchaseChequeAccountCategorySecondary,
            'purchaseChequeAccountCategoryPrimary' => $purchaseChequeAccountCategoryPrimary,
            'supplier' => $supplier,
            'error' => $error,
        ));
    }

    public function actionSummaryAjaxData($id, $index) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchaseCheque = new PurchaseCheque();

            if (!empty($id))
                $purchaseCheque->copyFromDb($id);

            if (!isset($_POST['PurchaseChequeDetail']))
                $purchaseCheque->details = array();

            $this->loadState($purchaseCheque);

            $amount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($purchaseCheque->details[$index], 'amount')));
            $total = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($purchaseCheque, 'total')));

            echo CJSON::encode(array(
                'amount' => $amount,
                'total' => $total,
            ));
        }
    }

    public function actionAjaxHtmlAddPurchaseReceipt($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchaseCheque = new PurchaseCheque();
            $this->loadState($purchaseCheque);

            $purchaseChequeAccountCategorySecondary = 'id IN(1, 48, 288, 160, 161, 370, 3, 467)';
            $purchaseChequeAccountCategoryPrimary = 'id IN (2, 47, 260, 160, 161, 463)';

            if (isset($_POST['PurchaseReceiptId']))
                $purchaseCheque->addPurchaseReceipt($_POST['PurchaseReceiptId']);

            $this->renderPartial('_detail', array(
                'purchaseCheque' => $purchaseCheque,
                'purchaseChequeAccountCategorySecondary' => $purchaseChequeAccountCategorySecondary,
                'purchaseChequeAccountCategoryPrimary' => $purchaseChequeAccountCategoryPrimary,
                'error' => false,
            ));
        }
    }

    public function actionView($id) {
        $purchaseCheque = PurchaseChequeHeader::model()->findByPk($id);

        $this->render('view', array(
            'purchaseCheque' => $purchaseCheque,
        ));
    }

    public function actionMemo($id) {
        if (!(Yii::app()->user->checkAccess('administrator'))) {
            if (!(isset(Yii::app()->session['PurchaseChequeMemoAllowed']) && Yii::app()->session['PurchaseChequeMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('PurchaseChequeMemoAllowed');

        $purchaseCheque = PurchaseChequeHeader::model()->findByPk($id);

        $purchaseChequeSupplier = ($purchaseCheque->is_non_tax) ? $purchaseCheque->supplier->name : $purchaseCheque->supplier->company;
        $purchaseChequeHeaderText = ($purchaseCheque->is_non_tax) ? '' : 'PT. Galatech Jaya Abadi';
        $this->render('memo', array(
            'purchaseCheque' => $purchaseCheque,
            'purchaseChequeSupplier' => $purchaseChequeSupplier,
            'purchaseChequeHeaderText' => $purchaseChequeHeaderText,
        ));
    }

    public function actionAdmin() {
        $purchaseCheque = new PurchaseChequeHeader('search');
        $purchaseCheque->unsetAttributes();

        if (isset($_GET['PurchaseChequeHeader']))
            $purchaseCheque->attributes = $_GET['PurchaseChequeHeader'];

        $supplierId = (isset($_GET['SupplierId'])) ? $_GET['SupplierId'] : '';

        $dataProvider = $purchaseCheque->search();

        $this->render('admin', array(
            'purchaseCheque' => $purchaseCheque,
            'dataProvider' => $dataProvider,
            'supplierId' => $supplierId,
        ));
    }

    public function actionDelete($id) {
        if (Yii::app()->request->isPostRequest) {
            $purchaseCheque = PurchaseChequeHeader::model()->findByPk($id);
            if ($purchaseCheque !== null) {
                $purchaseCheque->is_inactive = !$purchaseCheque->is_inactive;
                $purchaseCheque->update(array('is_inactive'));
            }

            if (!isset($_GET['ajax']))
                $this->redirect(isset($_POST['returnUrl']) ? $_POST['returnUrl'] : array('admin'));
        } else
            throw new CHttpException(400, 'Invalid request. Please do not repeat this request again.');
    }

    public function actionAjaxHtmlRemoveDetail($index) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchaseCheque = new PurchaseCheque();

            $this->loadState($purchaseCheque);

            $purchaseCheque->removeDetailAt($index);

            $this->renderPartial('_detail', array(
                'purchaseCheque' => $purchaseCheque,
                'error' => false,
            ));
        }
    }

    public function actionSupplierAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchaseCheque = new PurchaseCheque();

            if (!empty($id))
                $purchaseCheque->copyFromDb($id);

            if (!isset($_POST['PurchaseChequeDetail']))
                $purchaseCheque->details = array();

            $this->loadState($purchaseCheque);

            $object = array(
                'supplier_id' => $purchaseCheque->header->supplier->company,
                'supplier_name' => $purchaseCheque->header->supplier->name,
                'supplier_address' => $purchaseCheque->header->supplier->address,
            );
            echo CJSON::encode($object);
        }
    }

    public function actionAjaxHtmlResetDetail() {
        if (Yii::app()->request->isAjaxRequest) {
            $purchaseCheque = new PurchaseCheque();

            $this->loadState($purchaseCheque);

            if (isset($_POST['PurchaseChequeHeader']['supplier_id']))
                $purchaseCheque->resetDetail($_POST['PurchaseChequeHeader']['supplier_id']);

            $this->renderPartial('_detail', array(
                'purchaseCheque' => $purchaseCheque,
                'error' => false,
            ));
        }
    }

    public function actionReport() {
        $purchaseCheque = new PurchaseChequeHeader('search');
        $purchaseCheque->unsetAttributes();
        if (isset($_GET['PurchaseChequeHeader']))
            $purchaseCheque->attributes = $_GET['PurchaseChequeHeader'];

        $startDate = (isset($_GET['StartDate'])) ? $_GET['StartDate'] : '';
        $endDate = (isset($_GET['EndDate'])) ? $_GET['EndDate'] : '';
        $pageSize = (isset($_GET['PageSize'])) ? $_GET['PageSize'] : '';
        $currentPage = (isset($_GET['page'])) ? $_GET['page'] : '';
        $currentSort = (isset($_GET['sort'])) ? $_GET['sort'] : '';
        $supplierId = (isset($_GET['SupplierId'])) ? $_GET['SupplierId'] : '';

        $dataProvider = $purchaseCheque->search();
//		$dataProvider->criteria->compare('purchaseReceiptHeader.supplier_id', $supplierId);
//		$dataProvider->criteria->join = "INNER JOIN " . PurchaseReceiptHeader::model()->tableName() . " purchaseReceiptHeader ON purchaseReceiptHeader.id = t.purchase_receipt_header_id INNER JOIN " . Supplier::model()->tableName() . " supplier ON purchaseReceiptHeader.supplier_id = supplier.id";

        $page = array('size' => $pageSize, 'current' => $currentPage);
        $date = array('attribute' => 't.issue_date', 'start' => $startDate, 'end' => $endDate);

        $sort = new CSort(get_class($purchaseCheque));
//		$sort->attributes = array('issue_date', 'supplier.name');
        $sort->attributes = array('issue_date');

        $dataProvider = ReportHelper::finalizeDataProvider($dataProvider, $page, $sort, $date);

        $this->render('report', array(
            'purchaseCheque' => $purchaseCheque,
            'dataProvider' => $dataProvider,
            'startDate' => $startDate,
            'endDate' => $endDate,
            'sort' => $sort,
            'currentSort' => $currentSort,
            'supplierId' => $supplierId,
        ));
    }

    protected function loadState($purchaseCheque) {
        if (isset($_POST['PurchaseChequeHeader'])) {
            $purchaseCheque->header->attributes = $_POST['PurchaseChequeHeader'];
        }
        if (isset($_POST['PurchaseChequeDetail'])) {
            foreach ($_POST['PurchaseChequeDetail'] as $i => $item) {
                if (isset($purchaseCheque->details[$i]))
                    $purchaseCheque->details[$i]->attributes = $item;
                else {
                    $detail = new PurchaseChequeDetail();
                    $detail->attributes = $item;
                    $purchaseCheque->details[] = $detail;
                }
            }
            if (count($_POST['PurchaseChequeDetail']) < count($purchaseCheque->details))
                array_splice($purchaseCheque->details, $i + 1);
        }
    }
}
