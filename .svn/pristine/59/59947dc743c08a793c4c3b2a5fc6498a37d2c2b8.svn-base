<h1> Penerimaan Giro Penjualan</h1>

<div class="form">

<?php echo CHtml::beginForm(); ?>

	<div class="container">
		<div class="span-12">
			<div class="row">
				<?php echo CHtml::label('Penerimaan Giro #', false); ?>
				<?php echo CHtml::encode(CHtml::value($cheque->header, 'number')); ?>
			</div>

			<div class="row">
				<?php echo CHtml::label('Tanggal Terima', false); ?>
				<?php $this->widget('zii.widgets.jui.CJuiDatePicker', array(
						'model'=>$cheque->header,
						'attribute'=>'receive_date',
						// additional javascript options for the date picker plugin
						'options'=>array(
								'dateFormat'=>'yy-mm-dd',
						),
						'htmlOptions'=>array(
								'readonly'=>true,
						),
				)); ?>
				<?php echo CHtml::error($cheque->header, 'receive_date'); ?>
			</div>

			<div class="row">
				<?php echo CHtml::label('Jatuh Tempo', false); ?>
				<?php $this->widget('zii.widgets.jui.CJuiDatePicker', array(
					'model'=>$cheque->header,
					'attribute'=>'due_date',
					// additional javascript options for the date picker plugin
					'options'=>array(
							'dateFormat'=>'yy-mm-dd',
					),
					'htmlOptions'=>array(
							'readonly'=>true,
					),
				)); ?>
				<?php echo CHtml::error($cheque->header, 'due_date'); ?>
			</div>
			
			<div class="row">
				<?php echo CHtml::label('Catatan', ''); ?>
				<?php echo CHtml::activeTextArea($cheque->header, 'note', array('rows'=>5, 'cols'=>30)); ?>
				<?php echo CHtml::error($cheque->header, 'note'); ?>
			</div>
		</div>

		<div class="span-12 last">
			<div class="row">
				<?php echo CHtml::activeLabelEx($cheque->header, 'bank'); ?>
				<?php echo CHtml::activeTextField($cheque->header, 'bank'); ?>
				<?php echo CHtml::error($cheque->header, 'bank'); ?>
			</div>

			<div class="row">
				<?php echo CHtml::activeLabelEx($cheque->header, 'Giro/Cek #'); ?>
				<?php echo CHtml::activeTextField($cheque->header, 'cheque_number'); ?>
				<?php echo CHtml::error($cheque->header, 'cheque_number'); ?>
			</div>
			
			<div class="row">
				<?php echo CHtml::activeLabelEx($cheque->header, 'Jumlah (Rp)'); ?>
				<?php echo CHtml::activeTextField($cheque->header, 'amount', array(
					'onchange'=>CHtml::ajax(array(
						'type'=>'POST',
						'dataType'=>'JSON',
						'url'=>CController::createUrl('amountAjaxData', array('id'=>$cheque->header->id)),
						'success'=>'function(data) {
								$("#amount").html(data.amount);
						}',
					)),
				)); ?>
				<div id="amount" style="text-align: left; font-size: smaller">
					<?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($cheque->header, 'amount'))); ?>
				</div>
				<?php echo CHtml::error($cheque->header, 'amount'); ?>
			</div>
			
			<div class="row">
				<?php echo CHtml::label('Tanda Terima #', ''); ?>
				<?php echo CHtml::activeTextField($cheque->header,'receipt_header_id', array('readonly'=>true, 'onclick'=>'$("#receipt-header-dialog").dialog("open"); return false;', 'onkeypress'=>'if (event.keyCode == 13) { $("#receipt-header-dialog").dialog("open"); return false; }')); ?>
				<?php echo CHtml::openTag('span', array('id'=>'receipt_header_number')); ?>
				<?php echo CHtml::encode(CHtml::value($cheque->header,'receiptHeader.number')); ?>
				<?php echo CHtml::closeTag('span'); ?>
				<?php echo CHtml::error($cheque->header,'receipt_header_id'); ?>

				<?php $this->beginWidget('zii.widgets.jui.CJuiDialog', array(
					'id'=>'receipt-header-dialog',
					// additional javascript options for the dialog plugin
					'options'=>array(
						'title'=>'Receipt',
						'autoOpen'=>false,
						'width'=>'auto',
						'modal'=>true,
					),
				)); ?>
				<?php $this->widget('zii.widgets.grid.CGridView', array(
					'id'=>'receipt-header-grid',
					'dataProvider'=>$receiptHeader->searchByReceipt(),
					'filter'=>$receiptHeader,
					'selectionChanged'=>'js:function(id) {
						$("#'.CHtml::activeId($cheque->header, 'receipt_header_id').'").val($.fn.yiiGridView.getSelection(id));
						$("#receipt-header-dialog").dialog("close");
						if ($.fn.yiiGridView.getSelection(id) == "")
						{
							$("#receipt_header_number").html("");
							$("#receipt_header_date").html("");
							$("#receipt_header_customer").html("");
						}
						else
						{
							$.ajax({
								type: "POST",
								dataType: "JSON",
								url: "'.CController::createUrl('receiptAjaxData', array('id'=>$cheque->header->id)).'",
								data: $("form").serialize(),
								success: function(data) {
									$("#receipt_header_number").html(data.receipt_header_number);
									$("#receipt_header_date").html(data.receipt_header_date);
									$("#receipt_header_customer").html(data.receipt_header_customer);
								},
							});
						}
					}',
					'columns'=>array(
						'number',
						'date',
						array(
							'name' => 'customer_id',
							'filter' => CHtml::listData(Customer::model()->findAll(), 'id', 'company'),
							'value' => 'CHtml::value($data, "customer.company")',
						),
//						array(
//							'header' => 'Total',
//							'filter' => false,
//							'value' => 'number_format($data->totalInvoice, 2)',
//							'htmlOptions' => array(
//								'style'=>'text-align: right',
//							)
//						),
					),
				)); ?>
				<?php $this->endWidget('zii.widgets.jui.CJuiDialog'); ?>
			</div>

			<div class="row">
				<?php echo CHtml::activeLabelEx($cheque->header,'Tanggal Tanda Terima'); ?>
				<?php echo CHtml::openTag('span', array('id'=>'receipt_header_date')); ?>
				<?php echo CHtml::encode(CHtml::value($cheque->header,'receiptHeader.date')); ?>
				<?php echo CHtml::closeTag('span'); ?>
			</div>
			
			<div class="row">
				<?php echo CHtml::activeLabelEx($cheque->header,'receiptHeader.customer_id'); ?>
				<?php echo CHtml::openTag('span', array('id'=>'receipt_header_customer')); ?>
				<?php echo CHtml::encode(CHtml::value($cheque->header,'receiptHeader.customer.company')); ?>
				<?php echo CHtml::closeTag('span'); ?>
			</div>

		</div>
	</div>

	<hr />
   
	<div class="row buttons">
		<?php echo CHtml::submitButton('Submit', array('name'=>'Submit', 'confirm'=>'Are you sure you want to save?')); ?>
	</div>

