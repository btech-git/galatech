<h1>Kelola Data Pembelian Barang</h1>

<?php $this->widget('zii.widgets.grid.CGridView', array(
	'id'=>'purchase-grid',
	'dataProvider'=>$dataProvider,
	'filter'=>$purchase,
	'columns'=>array(
		'number',
		array(
			'header' => 'Tanggal',
			'name' => 'date',
			'value' => 'Yii::app()->dateFormatter->format("d MMMM yyyy", $data->date)'
		),
		array(
			'name' => 'supplier_id',
			'filter' => CHtml::listData(Supplier::model()->findAll(array('order' => 'company ASC')), 'id', 'company'),
			'value' => '$data->supplier->company',
		),
		array(
			'name' => 'admin_id',
			'filter' => CHtml::listData(Admin::model()->findAll(), 'id', 'name'),
			'value' => '$data->admin->name',
		),
		array(
			'name'=>'is_inactive',
			'filter' => array(ActiveRecord::ACTIVE=>'Active', ActiveRecord::INACTIVE=>'Inactive'),
			'value'=>'$data->status()',
		),
		array(
			'class'=>'CButtonColumn',
			'updateButtonUrl'=>'CHtml::normalizeUrl(array("create", "id"=>$data->id))',
		),
	),
)); ?>
