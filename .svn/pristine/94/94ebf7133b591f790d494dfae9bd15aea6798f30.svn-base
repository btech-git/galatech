<?php

class Receive extends CComponent {

    public $header;
    public $details;

    public function __construct() {
        $this->header = new ReceiveHeader();
        $this->details = array();
    }

    public function copyFromDb($id) {
        $this->header = ReceiveHeader::model()->resetScope()->findByPk($id);
        $this->details = ReceiveDetail::model()->resetScope()->findAllByAttributes(array('receive_header_id' => $id));
    }

    public function addProductByPurchase($id) {
        $sql = "SELECT p.id, p.product_id, p.quantity - SUM(COALESCE(r.quantity, 0)) AS quantity_purchased
                FROM " . PurchaseDetail::model()->tableName() . " p
                LEFT OUTER JOIN " . ReceiveDetail::model()->tableName() . " r ON p.id = r.purchase_detail_id
                WHERE p.purchase_header_id = :purchase_header_id AND p.is_inactive = 0
                GROUP BY p.id
                HAVING quantity_purchased > 0";

        $resultSet = CActiveRecord::$db->createCommand($sql)->queryAll(true, array(':purchase_header_id' => $id));

        $this->details = array();

        foreach ($resultSet as $row) {
            $detail = new ReceiveDetail();

            $detail->product_id = $row['product_id'];
            $detail->purchase_detail_id = $row['id'];

            $this->details[] = $detail;
        }
    }

    public function removeProductAt($index) {
        array_splice($this->details, $index, 1);
    }

    public function validate() {
        $valid = $this->header->validate();

        $valid = $valid && $this->validateDetailsQuantity();
        
        if (count($this->details) > 0) {
            foreach ($this->details as $detail) {
                $fields = array('quantity', 'unit_price', 'product_id');
                $valid = $detail->validate($fields) && $valid;
            }
        } else {
            $valid = false;
        }

        return $valid;
    }

    public function validateDetailsQuantity() {
        $valid = true;
        
        foreach ($this->details as $detail) {
            if ($detail->purchaseDetail->quantity < $detail->quantity) {
                $valid = false;
                $this->header->addError('error', 'Quantity receive must be equal or less than quantity order!');
            }
        }
        
        return $valid;
    }

    public function save($runValidation) {
        
        $isNewRecord = $this->header->isNewRecord;
        $valid = $this->header->save($runValidation);
        Inventory::model()->deleteAllByAttributes(array('transaction_number' => $this->header->number));

        foreach ($this->details as $detail) {
//            if ($detail->quantity == 0) {
//                continue;
//            }
            
            $detail->receive_header_id = $this->header->id;
            
            if ($isNewRecord) {
                $detail->delivered_quantity = 0;
                $detail->delivery_available_quantity = $detail->quantity;
                $detail->purchase_unit_price = $detail->purchaseDetail->unit_price;
                $detail->has_delivery = 0;
            }
            $valid = $detail->save($runValidation) && $valid;
            
            $detail->purchaseDetail->quantity_received = $detail->purchaseDetail->getTotalQuantityReceived();
            $detail->purchaseDetail->quantity_received_remaining = $detail->purchaseDetail->quantity - $detail->purchaseDetail->quantity_received;
            $valid = $detail->purchaseDetail->update(array('quantity_received', 'quantity_received_remaining')) && $valid;

            if ((int) $detail->is_inactive === 0) {
                $inventory = new Inventory();
                $inventory->transaction_number = $this->header->number;
                $inventory->transaction_type = 1;
                $inventory->transaction_subject = $this->header->purchaseHeader->supplier->company;
                $inventory->product_id = $detail->product_id;
                $inventory->admin_id = $this->header->admin_id;
                $inventory->date = $this->header->date;
                $inventory->quantity_in = $detail->quantity;
                $inventory->warehouse_id = $this->header->warehouse_id;

                $valid = $inventory->save() && $valid;
            }
        }
        
        $this->header->purchaseHeader->total_quantity_received = $this->header->purchaseHeader->getTotalQuantityReceived();
        $this->header->purchaseHeader->total_quantity_received_remaining = $this->header->purchaseHeader->total_quantity - $this->header->purchaseHeader->total_quantity_received;        
        $valid = $valid && $this->header->purchaseHeader->update(array('total_quantity_received', 'total_quantity_received_remaining'));

        return $valid;
    }

    public function update() {
        $valid = $this->header->update();

        foreach ($this->details as $detail) {
            $valid = $detail->update() && $valid;
        }

        return $valid;
    }

    public function getAmount() {
        $amount = 0.00;
        
        foreach ($this->details as $detail) {
            $purchaseDetail = PurchaseDetail::model()->findByAttributes(array('purchase_header_id' => $this->header->purchase_header_id, 'product_id' => $detail->product_id));
            $unitPrice = ($purchaseDetail === null) ? 0.00 : $purchaseDetail->unit_price * (1 - $purchaseDetail->discount / 100) * (1 - $purchaseDetail->purchaseHeader->discount / 100);
            $amount = $detail->quantity * $unitPrice;
        }

        return $amount;
    }

    public function getSubTotalQuantity() {
        $total = 0.00;
        
        foreach ($this->details as $detail) {
            $total += $detail->quantity;
        }

        return $total;
    }
}
