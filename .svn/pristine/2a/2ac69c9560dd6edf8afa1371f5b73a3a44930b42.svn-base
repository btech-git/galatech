<?php
$this->breadcrumbs = array(
    'Delivery' => array('/transaction/delivery/create'),
    'View',
);
?>
<h1><?php echo $this->id . '/' . $this->action->id; ?></h1>

<?php
$this->widget('zii.widgets.CDetailView', array(
    'data' => $delivery,
    'attributes' => array(
        array(
            'label' => 'Pengiriman #',
            'value' => $delivery->number,
        ),
        array(
            'label' => 'Tanggal',
            'value' => Yii::app()->dateFormatter->format("d MMMM yyyy", $delivery->date),
        ),
        array(
            'label' => 'Gudang',
            'value' => $delivery->warehouse->name,
        ),
        array(
            'label' => 'Pengirim',
            'value' => $delivery->driver,
        ),
        array(
            'label' => 'No. Kendaraan',
            'value' => $delivery->plate_number,
        ),
        array(
            'label' => 'Customer',
            'value' => $delivery->customer->company,
        ),
        array(
            'label' => 'Catatan',
            'value' => $delivery->note,
        ),
    ),
));
?>

<?php
$this->widget('zii.widgets.grid.CGridView', array(
    'id' => 'delivery-detail-grid',
    'dataProvider' => new CArrayDataProvider($delivery->deliveryDetails),
    'columns' => array(
        'product_name: Nama Barang',
        'product.size: Ukuran',
        array(
            'header' => 'Jumlah',
            'value' => 'number_format($data->quantity, 0)',
            'htmlOptions' => array(
                'style' => 'text-align: right',
            ),
        ),
        'product.unit.name: Satuan',
        array(
            'header' => 'Harga Satuan',
            'value' => 'number_format($data->unit_price, 2)',
            'htmlOptions' => array(
                'style' => 'text-align: right',
            ),
        ),
        'discount: Diskon (%)',
        array(
            'header' => 'Total',
            'value' => 'number_format($data->total, 2)',
            'htmlOptions' => array(
                'style' => 'text-align: right',
            ),
        ),
    ),
));
?>
<table>
    <tr style="background-color: aquamarine">
        <td style="text-align: right;width: 40%;">Total Qty</td>
        <td style="text-align: right;width: 10%;">
            <?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', $delivery->subTotalQuantity)); ?>
        </td>
        <td style="text-align: right;width: 40%;">Sub Total:</td>
        <td style="text-align: right;width: 10%;">
            <?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->subTotal)); ?>
        </td>
    </tr>
</table>

<div id="link">
    <?php echo CHtml::link('Create', array('create')); ?>
    <?php echo CHtml::link('Manage', array('admin')); ?>
    <?php echo CHtml::link('Edit', array('create', 'id'=>$delivery->id)); ?>
    <?php echo CHtml::link('Print Pengiriman Barang', array('memo', 'id' => $delivery->id), array('target' => '_blank')); ?>
</div>