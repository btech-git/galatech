<?php

class SalesDownpaymentController extends Controller {

    public function filters() {
        return array(
            'access',
        );
    }

    public function filterAccess($filterChain) {
        $taxCreateValid = Yii::app()->user->checkAccess('tSalesDownpaymentCreate') || Yii::app()->user->checkAccess('tsSalesDownpaymentCreate');
        $nonTaxCreateValid = Yii::app()->user->checkAccess('ntSalesDownpaymentCreate');
        $taxEditValid = Yii::app()->user->checkAccess('tSalesDownpaymentEdit') || Yii::app()->user->checkAccess('tsSalesDownpaymentEdit');
        $nonTaxEditValid = Yii::app()->user->checkAccess('ntSalesDownpaymentEdit');

        if ($filterChain->action->id === 'create') {
            $params = $filterChain->controller->actionParams;

            if (isset($params['id'])) {
                if (!($taxEditValid || $nonTaxEditValid))
                    $this->redirect(array('/site/login'));
            } else {
                if (isset($params['nt'])) {
                    if (!$nonTaxCreateValid)
                        $this->redirect(array('/site/login'));
                } else {
                    if (!$taxCreateValid)
                        $this->redirect(array('/site/login'));
                }
            }
        }
        if ($filterChain->action->id === 'amountAjaxData' || $filterChain->action->id === 'customerAjaxData' || $filterChain->action->id === 'memo' || $filterChain->action->id === 'view') {
            if (!($taxCreateValid || $nonTaxCreateValid || $taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'delete' || $filterChain->action->id === 'admin') {
            if (!($taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'report') {
            if (!(Yii::app()->user->checkAccess('ntSalesDownpaymentReport') || Yii::app()->user->checkAccess('tSalesDownpaymentReport') || Yii::app()->user->checkAccess('tsSalesDownpaymentReport')))
                $this->redirect(array('/site/login'));
        }

        $filterChain->run();
    }

    public function actionCreate() {
        $salesDownpayment = new SalesDownpaymentTransaction();

        $customer = new Customer('search');
        $customer->unsetAttributes();  // clear any default values
        if (isset($_GET['Customer']))
            $customer->attributes = $_GET['Customer'];

        if (isset($_GET['id']))
            $salesDownpayment->copyFromDb($_GET['id']);

        if ($salesDownpayment->header->isNewRecord) {
            $salesDownpayment->header->is_non_tax = intval(isset($_GET['nt']));
            $salesDownpayment->header->number = CodeNumber::make(array($salesDownpayment->header, DeliveryHeader::model()), 'number', 'DLV', ($salesDownpayment->header->is_non_tax) ? true : false);
        }

        $salesDownpayment->header->admin_id = Yii::app()->user->id;
        $this->loadState($salesDownpayment);

        $error = false;

        if (isset($_POST['Submit']) && IdempotentManager::check()) {
            $dbTransaction = CActiveRecord::$db->beginTransaction();
            try {
                if ($salesDownpayment->validate() && IdempotentManager::build()->save() && $salesDownpayment->save(false)) {
                    $dbTransaction->commit();
                    Yii::app()->session['SalesDownPaymentMemoAllowed'] = true;
                    $this->redirect(array('view', 'id' => $salesDownpayment->header->id));
                } else {
                    $dbTransaction->rollback();
                    $error = true;
                }
            } catch (Exception $e) {
                $dbTransaction->rollback();
                throw new CHttpException($e->getCode(), $e->getMessage());
            }
        }

        $this->render('create', array(
            'salesDownpayment' => $salesDownpayment,
            'customer' => $customer,
            'error' => $error,
        ));
    }

    public function actionView($id) {
        $salesDownpayment = SalesDownpayment::model()->findByPk($id);

        $this->render('view', array(
            'salesDownpayment' => $salesDownpayment,
        ));
    }

    public function actionMemo($id) {
        if (!(Yii::app()->user->checkAccess('administrator'))) {
            if (!(isset(Yii::app()->session['SalesDownPaymentMemoAllowed']) && Yii::app()->session['SalesDownPaymentMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('SalesDownPaymentMemoAllowed');

        $salesDownpayment = SalesDownpayment::model()->findByPk($id);

        $salesDownpaymentCustomer = ($salesDownpayment->is_non_tax) ? $salesDownpayment->customer->name : $salesDownpayment->customer->company;
        $salesDownpaymentHeaderText = ($salesDownpayment->is_non_tax) ? '' : 'PT. Galatech Jaya Abadi';

        $this->render('memo', array(
            'salesDownpayment' => $salesDownpayment,
            'salesDownpaymentCustomer' => $salesDownpaymentCustomer,
            'salesDownpaymentHeaderText' => $salesDownpaymentHeaderText,
        ));
    }

    public function actionDelete($id) {
        if (Yii::app()->request->isPostRequest) {
            $salesDownpayment = SalesDownpayment::model()->resetScope()->findByPk($id);
            if ($salesDownpayment !== null) {
                $salesDownpayment->is_inactive = !$salesDownpayment->is_inactive;
                $salesDownpayment->update(array('is_inactive'));
            }

            if (!isset($_GET['ajax']))
                $this->redirect(isset($_POST['returnUrl']) ? $_POST['returnUrl'] : array('admin'));
        } else
            throw new CHttpException(400, 'Invalid request. Please do not repeat this request again.');
    }

    public function actionAdmin() {
        $salesDownpayment = new SalesDownpayment('search');
        $salesDownpayment->unsetAttributes();

        if (isset($_GET['SalesDownpayment']))
            $salesDownpayment->attributes = $_GET['SalesDownpayment'];

        $dataProvider = $salesDownpayment->search();
        $dataProvider->model->resetScope();

        $this->render('admin', array(
            'salesDownpayment' => $salesDownpayment,
            'dataProvider' => $dataProvider,
        ));
    }

    public function actionReport() {
        $salesDownpayment = new SalesDownpayment('search');
        $salesDownpayment->unsetAttributes();
        if (isset($_GET['SalesDownpayment']))
            $salesDownpayment->attributes = $_GET['SalesDownpayment'];

        $startDate = (isset($_GET['StartDate'])) ? $_GET['StartDate'] : '';
        $endDate = (isset($_GET['EndDate'])) ? $_GET['EndDate'] : '';
        $pageSize = (isset($_GET['PageSize'])) ? $_GET['PageSize'] : '';
        $currentPage = (isset($_GET['page'])) ? $_GET['page'] : '';
        $currentSort = (isset($_GET['sort'])) ? $_GET['sort'] : '';

        $dataProvider = $salesDownpayment->search();
        $dataProvider->criteria->with = array('customer');

        $page = array('size' => $pageSize, 'current' => $currentPage);
        $date = array('attribute' => 'date', 'start' => $startDate, 'end' => $endDate);

        $sort = new CSort(get_class($salesDownpayment));
        $sort->attributes = array('date', 'customer.name');

        $dataProvider = ReportHelper::finalizeDataProvider($dataProvider, $page, $sort, $date);

        $this->render('report', array(
            'salesDownpayment' => $salesDownpayment,
            'dataProvider' => $dataProvider,
            'startDate' => $startDate,
            'endDate' => $endDate,
            'sort' => $sort,
            'currentSort' => $currentSort,
        ));
    }

    public function actionAmountAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesDownpayment = new SalesDownpaymentTransaction();

            if (!empty($id))
                $salesDownpayment->copyFromDb($id);

            $this->loadState($salesDownpayment);

            $amount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($salesDownpayment->header, 'amount')));
            $tax = CHtml::encode(Yii::app()->numberFormatter->format('#,##0', CHtml::value($salesDownpayment->header, 'tax')));

            echo CJSON::encode(array(
                'amount' => $amount,
                'tax' => $tax,
            ));
        }
    }

    public function actionCustomerAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $salesDownpayment = new SalesDownpaymentTransaction();

            if (!empty($id))
                $salesDownpayment->copyFromDb($id);

            $this->loadState($salesDownpayment);

            $object = array(
                'customer_id' => $salesDownpayment->header->customer->id,
                'customer_name' => $salesDownpayment->header->customer->company,
            );
            echo CJSON::encode($object);
        }
    }

    protected function loadState(&$salesDownpayment) {
        if (isset($_POST['SalesDownpayment'])) {
            $salesDownpayment->header->attributes = $_POST['SalesDownpayment'];
        }
    }
}
