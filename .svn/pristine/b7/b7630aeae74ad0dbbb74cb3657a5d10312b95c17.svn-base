<h1>Pembelian Asset</h1>

<div class="form">

<?php echo CHtml::beginForm(); ?>
        
        <div class="container">
                <div class="span-12">
					<div class="row">
						<?php echo CHtml::label('Pembelian #', false); ?>
						<?php echo CHtml::encode(CHtml::value($purchaseAsset->header, 'number')); ?>
						<?php echo CHtml::error($purchaseAsset->header, 'number'); ?>
					</div>
					
					<div class="row">
						<?php echo CHtml::label('Tanggal', false); ?>
						<?php $this->widget('zii.widgets.jui.CJuiDatePicker', array(
								'model'=>$purchaseAsset->header,
								'attribute'=>'date',
								// additional javascript options for the date picker plugin
								'options'=>array(
										'dateFormat'=>'yy-mm-dd',
								),
								'htmlOptions'=>array(
										'readonly'=>true,
								),
						)); ?>
						<?php echo CHtml::error($purchaseAsset->header, 'date'); ?>
					</div>
					
					<div class="row">
						<?php echo CHtml::label('Supplier', ''); ?>
						<?php echo CHtml::activeTextField($purchaseAsset->header, 'supplier', array('size'=>20,'maxLength'=>60)); ?>
						<?php echo CHtml::error($purchaseAsset->header, 'supplier'); ?>
					</div>
                </div>
        
                <div class="span-12 last">
					<div class="row">
						<?php echo CHtml::label('Catatan', ''); ?>
						<?php echo CHtml::activeTextArea($purchaseAsset->header, 'note', array('rows'=>5, 'cols'=>30)); ?>
						<?php echo CHtml::error($purchaseAsset->header, 'note'); ?>
					</div>
                </div>
        </div>
        
        <hr />
        
        <div class="row buttons">
                <?php echo CHtml::button('Tambah Data Barang', array(
                        'onclick'=>CHtml::ajax(array(
                                'type'=>'POST',
                                'url'=>CController::createUrl('AddItemAjax', array('id'=>$purchaseAsset->header->id)),
                                'update'=>'#detail_div',
                        )),
                )); ?>
        </div>
        
        <div id="detail_div">
                <?php $this->renderPartial('_detail', array('purchaseAsset'=>$purchaseAsset, 'error'=>$error)); ?>
        </div>

	<div class="row buttons">
		<?php echo CHtml::submitButton('Submit', array('name'=>'Submit', 'confirm'=>'Are you sure you want to save?')); ?>
	</div>

<?php echo CHtml::endForm(); ?>

</div><!-- form -->
