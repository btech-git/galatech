    public function actionGrandTotalAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $delivery = new Delivery();

//            if (!empty($id)) {
//                $delivery->copyFromDb($id);
//            }

            if (!isset($_POST['DeliveryDetail'])) {
                $delivery->details = array();
            }

            $this->loadState($delivery);

            $downpayment = CHtml::listOptions('', CHtml::listData(SalesDownpayment::model()->findAllByAttributes(array('customer_id' => $delivery->header->customer_id), array('condition' => "id IN (" . SqlViewGenerator::existDownpaymentList() . ")")), 'id', 'amount'), ($htmlOptions = array('empty' => '')));
            $delivery->header->sales_downpayment_id = '';
            $discount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->calculatedDiscount));
            $tax = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->calculatedTax));
            $grandTotal = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->grandTotal));

            echo CJSON::encode(array(
                'downpayment' => $downpayment,
                'discount' => $discount,
                'tax' => $tax,
                'grandTotal' => $grandTotal,
            ));
        }
    }

    protected function loadState(&$delivery) {
        if (isset($_POST['DeliveryHeader'])) {
            $delivery->header->attributes = $_POST['DeliveryHeader'];
        }
        if (isset($_POST['DeliveryDetail'])) {
            foreach ($_POST['DeliveryDetail'] as $i => $item) {
                if (isset($delivery->details[$i]))
                    $delivery->details[$i]->attributes = $item;
                else {
                    $detail = new DeliveryDetail();
                    $detail->attributes = $item;
                    $delivery->details[] = $detail;
                }
            }
            if (count($_POST['DeliveryDetail']) < count($delivery->details))
                array_splice($delivery->details, $i + 1);
        }
    }
}
