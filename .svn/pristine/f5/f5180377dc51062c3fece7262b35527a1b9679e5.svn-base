<?php

class DeliveryController extends SelectionController {

    public function filters() {
        return array(
            'access',
        );
    }

    public function filterAccess($filterChain) {
        $taxCreateValid = Yii::app()->user->checkAccess('tDeliveryCreate') || Yii::app()->user->checkAccess('tsDeliveryCreate');
        $nonTaxCreateValid = Yii::app()->user->checkAccess('ntDeliveryCreate');
        $taxEditValid = Yii::app()->user->checkAccess('tDeliveryEdit') || Yii::app()->user->checkAccess('tsDeliveryEdit');
        $nonTaxEditValid = Yii::app()->user->checkAccess('ntDeliveryEdit');

        if ($filterChain->action->id === 'create') {
            $params = $filterChain->controller->actionParams;

            if (isset($params['id'])) {
                if (!($taxEditValid || $nonTaxEditValid))
                    $this->redirect(array('/site/login'));
            } else {
                if (isset($params['nt'])) {
                    if (!$nonTaxCreateValid)
                        $this->redirect(array('/site/login'));
                } else {
                    if (!$taxCreateValid)
                        $this->redirect(array('/site/login'));
                }
            }
        }
        if ($filterChain->action->id === 'customerCompletion' || $filterChain->action->id === 'addProductAjax' || $filterChain->action->id === 'discountTaxTotalAjaxData' || $filterChain->action->id === 'downpaymentTaxTotalAjaxData' || $filterChain->action->id === 'grandTotalAjaxData' || $filterChain->action->id === 'removeProductAjax' || $filterChain->action->id === 'taxTotalAjaxData' || $filterChain->action->id === 'totalAjaxData' || $filterChain->action->id === 'updateAllProductAjax' || $filterChain->action->id === 'memo' || $filterChain->action->id === 'view') {
            if (!($taxCreateValid || $nonTaxCreateValid || $taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'delete' || $filterChain->action->id === 'admin') {
            if (!($taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'report') {
            if (!(Yii::app()->user->checkAccess('ntDeliveryReport') || Yii::app()->user->checkAccess('tDeliveryReport') || Yii::app()->user->checkAccess('tsDeliveryReport')))
                $this->redirect(array('/site/login'));
        }

        $filterChain->run();
    }

    public function actionCreate() {
        $delivery = new Delivery();

        if (isset($_GET['id'])) {
            $delivery->copyFromDb($_GET['id']);
        }

        $product = new Product('search');
        $product->unsetAttributes();

        if (isset($_GET['Product'])) {
            $product->attributes = $_GET['Product'];
        }

        if (empty($delivery->header->id)) {
//            $delivery->header->number = CodeNumber::make(array($delivery->header, SalesDownpayment::model()), 'number', ($delivery->header->is_non_tax) ? 'NDLV' : 'DLV', ($delivery->header->is_non_tax) ? true : false);
            $delivery->header->date = date('Y-m-d');
            $delivery->header->tax = 11;
            $delivery->header->tax_type = 2;
            $delivery->header->is_non_tax = 0;
        }
        $delivery->header->admin_id = Yii::app()->user->id;
        $this->loadState($delivery);

        $error = false;

        if (isset($_POST['Submit']) && IdempotentManager::check()) {
            if (empty($delivery->header->id)) {
                $delivery->header->number = CodeNumber::make(array($delivery->header, SalesDownpayment::model()), 'number', ($delivery->header->is_non_tax) ? 'NDLV' : 'DLV', ($delivery->header->is_non_tax) ? true : false);
            }

            $dbTransaction = CActiveRecord::$db->beginTransaction();
            try {
                if ($delivery->validate() && IdempotentManager::build()->save() && $delivery->save(false)) {
                    $dbTransaction->commit();
                    Yii::app()->session['DeliveryMemoAllowed'] = true;
                    $this->redirect(array('view', 'id' => $delivery->header->id));
                } else {
                    $dbTransaction->rollback();
                    $error = true;
                }
            } catch (Exception $e) {
                $dbTransaction->rollback();
                throw new CHttpException($e->getCode(), $e->getMessage());
            }
        }

        $this->render('create', array(
            'delivery' => $delivery,
            'product' => $product,
            'error' => $error,
        ));
    }

    public function actionView($id) {
        $delivery = DeliveryHeader::model()->findByPk($id);

        $this->render('view', array(
            'delivery' => $delivery,
        ));
    }

    public function actionDelete($id) {
        if (Yii::app()->request->isPostRequest) {
            $delivery = DeliveryHeader::model()->findByPk($id);
            if ($delivery !== null) {
                $delivery->is_inactive = !$delivery->is_inactive;
                $delivery->update(array('is_inactive'));

                foreach ($delivery->deliveryDetails as $detail) {
                    $detail->is_inactive = !$detail->is_inactive;
                    $detail->update(array('is_inactive'));
                }
            }

            Inventory::model()->DeleteAllByAttributes(array(
                'transaction_number' => $delivery->number
            ));

            if (!isset($_GET['ajax']))
                $this->redirect(isset($_POST['returnUrl']) ? $_POST['returnUrl'] : array('admin'));
        } else
            throw new CHttpException(400, 'Invalid request. Please do not repeat this request again.');
    }

    public function actionMemo($id) {
        $this->layout = '//layouts/memo';
        
        if (!(Yii::app()->user->checkAccess('administrator') || Yii::app()->user->checkAccess('tDeliveryEdit') || Yii::app()->user->checkAccess('tsDeliveryEdit'))) {
            if (!(isset(Yii::app()->session['DeliveryMemoAllowed']) && Yii::app()->session['DeliveryMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('DeliveryMemoAllowed');

        $delivery = DeliveryHeader::model()->findByPk($id);

        $deliveryHeaderText = ($delivery->is_non_tax) ? '' : 'PT. Galatech Jaya Abadi';
        $deliveryCustomer = ($delivery->is_non_tax) ? $delivery->customer->name : $delivery->customer->company;

        $this->render('memo', array(
            'delivery' => $delivery,
            'deliveryHeaderText' => $deliveryHeaderText,
            'deliveryCustomer' => $deliveryCustomer,
        ));
    }

    public function actionAdmin() {
        $delivery = new DeliveryHeader('search');
        $delivery->unsetAttributes();

        if (isset($_GET['DeliveryHeader']))
            $delivery->attributes = $_GET['DeliveryHeader'];

        $this->render('admin', array(
            'delivery' => $delivery,
        ));
    }

    public function actionReport() {
        $deliveryHeader = new DeliveryHeader('search');
        $deliveryHeader->unsetAttributes();
        if (isset($_GET['DeliveryHeader']))
            $deliveryHeader->attributes = $_GET['DeliveryHeader'];

        $startDate = (isset($_GET['StartDate'])) ? $_GET['StartDate'] : '';
        $endDate = (isset($_GET['EndDate'])) ? $_GET['EndDate'] : '';
        $pageSize = (isset($_GET['PageSize'])) ? $_GET['PageSize'] : '';
        $currentPage = (isset($_GET['page'])) ? $_GET['page'] : '';
        $currentSort = (isset($_GET['sort'])) ? $_GET['sort'] : '';

        $dataProvider = $deliveryHeader->search();
        $dataProvider->criteria->with = array('customer');

        $page = array('size' => $pageSize, 'current' => $currentPage);
        $date = array('attribute' => 'date', 'start' => $startDate, 'end' => $endDate);

        $sort = new CSort(get_class($deliveryHeader));
        $sort->attributes = array('date', 'customer.name');

        $dataProvider = ReportHelper::finalizeDataProvider($dataProvider, $page, $sort, $date);

        $this->render('report', array(
            'deliveryHeader' => $deliveryHeader,
            'dataProvider' => $dataProvider,
            'startDate' => $startDate,
            'endDate' => $endDate,
            'sort' => $sort,
            'currentSort' => $currentSort,
        ));
    }

    public function actionAddProductAjax($id, $nt) {
        if (Yii::app()->request->isAjaxRequest) {
            $delivery = new Delivery();

//            if (!empty($id))
//                $delivery->copyFromDb($id);

            if ($delivery->header->isNewRecord)
                $delivery->header->is_non_tax = intval($nt);

//            if (!isset($_POST['DeliveryDetail']))
//                $delivery->details = array();

            $this->loadState($delivery);

            if (isset($_POST['ProductId']))
                $delivery->addProduct($_POST['ProductId']);

            $this->renderPartial('_detail', array(
                'delivery' => $delivery,
                'error' => false,
            ));
        }
    }

    public function actionRemoveProductAjax($id, $index) {
        if (Yii::app()->request->isAjaxRequest) {
            $delivery = new Delivery();

//            if (!empty($id))
//                $delivery->copyFromDb($id);

            if (!isset($_POST['DeliveryDetail']))
                $delivery->details = array();

            $this->loadState($delivery);

            $delivery->removeProductAt($index);

            $this->renderPartial('_detail', array(
                'delivery' => $delivery,
                'error' => false,
            ));
        }
    }

    public function actionUpdateAllProductAjax($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $delivery = new Delivery();

//            if (!empty($id))
//                $delivery->copyFromDb($id);

            if (!isset($_POST['DeliveryDetail']))
                $delivery->details = array();

            $this->loadState($delivery);

            $this->renderPartial('_detail', array(
                'delivery' => $delivery,
            ));
        }
    }

    public function actionCustomerCompletion() {
        echo CJSON::encode(Completion::customer($_GET['term']));
    }

    public function actionTotalAjaxData($id, $index) {
        if (Yii::app()->request->isAjaxRequest) {
            $delivery = new Delivery();

//            if (!empty($id))
//                $delivery->copyFromDb($id);

            if (!isset($_POST['DeliveryDetail']))
                $delivery->details = array();

            $this->loadState($delivery);

            $unitPrice = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($delivery->details[$index], 'unit_price')));
            $total = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->details[$index]->getTotal($delivery->header->tax_type, $delivery->header->tax)));
            $subTotal = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->subTotal));
            $discount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->calculatedDiscount));
            $tax = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->calculatedTax));
            $grandTotal = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $delivery->grandTotal));
            $subTotalQuantity = CHtml::encode(Yii::app()->numberFormatter->format('#,##0', $delivery->subTotalQuantity));

            echo CJSON::encode(array(
                'unitPrice' => $unitPrice,
                'total' => $total,
                'subTotal' => $subTotal,
                'discount' => $discount,
                'tax' => $tax,
                'grandTotal' => $grandTotal,
                'subTotalQuantity' => $subTotalQuantity
            ));
        }
    }

