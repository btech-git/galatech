<?php

class PurchaseController extends SelectionController {

    public function filters() {
        return array(
            'access',
        );
    }

    public function filterAccess($filterChain) {
        $taxCreateValid = Yii::app()->user->checkAccess('tPurchaseCreate') || Yii::app()->user->checkAccess('tsPurchaseCreate');
        $nonTaxCreateValid = Yii::app()->user->checkAccess('ntPurchaseCreate');
        $taxEditValid = Yii::app()->user->checkAccess('tPurchaseEdit') || Yii::app()->user->checkAccess('tsPurchaseEdit');
        $nonTaxEditValid = Yii::app()->user->checkAccess('ntPurchaseEdit');

        if ($filterChain->action->id === 'create') {
            $params = $filterChain->controller->actionParams;

            if (isset($params['id'])) {
                if (!($taxEditValid || $nonTaxEditValid))
                    $this->redirect(array('/site/login'));
            } else {
                if (isset($params['nt'])) {
                    if (!$nonTaxCreateValid)
                        $this->redirect(array('/site/login'));
                } else {
                    if (!$taxCreateValid)
                        $this->redirect(array('/site/login'));
                }
            }
        }
        if ($filterChain->action->id === 'shippingTotalAjaxData' || $filterChain->action->id === 'addProductAjax' || $filterChain->action->id === 'removeProductAjax' || $filterChain->action->id === 'discountTotalAjaxData' || $filterChain->action->id === 'totalAjaxData' || $filterChain->action->id === 'supplierCompletion' || $filterChain->action->id === 'taxTotalAjaxData' || $filterChain->action->id === 'memo' || $filterChain->action->id === 'view') {
            if (!($taxCreateValid || $nonTaxCreateValid || $taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'delete' || $filterChain->action->id === 'admin') {
            if (!($taxEditValid || $nonTaxEditValid))
                $this->redirect(array('/site/login'));
        }
        if ($filterChain->action->id === 'report') {
            if (!(Yii::app()->user->checkAccess('ntPurchaseReport') || Yii::app()->user->checkAccess('tPurchaseReport') || Yii::app()->user->checkAccess('tsPurchaseReport')))
                $this->redirect(array('/site/login'));
        }

        $filterChain->run();
    }

    public function actionCreate() {
        $purchase = new Purchase();

        if (isset($_GET['id']))
            $purchase->copyFromDb($_GET['id']);

        $product = new Product('search');
        $product->unsetAttributes();
        if (isset($_GET['Product']))
            $product->attributes = $_GET['Product'];

        if ($purchase->header->isNewRecord) {
            $purchase->header->is_non_tax = intval(isset($_GET['nt']));
            $purchase->header->number = CodeNumber::make($purchase->header, 'number', ($purchase->header->is_non_tax) ? 'NPRC' : 'PRC', ($purchase->header->is_non_tax) ? true : false);
        }

        $purchase->header->admin_id = Yii::app()->user->id;
        $purchase->header->tax = 11;
        $purchase->header->tax_type = 1;
        $this->loadState($purchase);

        $error = false;

        if (isset($_POST['Submit']) && IdempotentManager::check()) {
            $dbTransaction = CActiveRecord::$db->beginTransaction();
            try {
                if ($purchase->validate() && IdempotentManager::build()->save() && $purchase->save(false)) {
                    $dbTransaction->commit();
                    Yii::app()->session['PurchaseMemoAllowed'] = true;
                    $this->redirect(array('view', 'id' => $purchase->header->id));
                } else {
                    $dbTransaction->rollback();
                    $error = true;
                }
            } catch (Exception $e) {
                $dbTransaction->rollback();
                throw new CHttpException($e->getCode(), $e->getMessage());
            }
        }

        $this->render('create', array(
            'purchase' => $purchase,
            'product' => $product,
            'error' => $error,
        ));
    }

    public function actionView($id) {
        $purchase = PurchaseHeader::model()->findByPk($id);

        $this->render('view', array(
            'purchase' => $purchase,
        ));
    }

    public function actionDelete($id) {
        if (Yii::app()->request->isPostRequest) {
            $purchaseHeader = PurchaseHeader::model()->resetScope()->findByPk($id);
            if ($purchaseHeader !== null) {
                $purchaseHeader->is_inactive = !$purchaseHeader->is_inactive;
                $purchaseHeader->update(array('is_inactive'));
            }

            if (!isset($_GET['ajax']))
                $this->redirect(isset($_POST['returnUrl']) ? $_POST['returnUrl'] : array('admin'));
        } else
            throw new CHttpException(400, 'Invalid request. Please do not repeat this request again.');
    }

    public function actionMemo($id) {
        if (!(Yii::app()->user->checkAccess('administrator') || Yii::app()->user->checkAccess('tPurchaseEdit') || Yii::app()->user->checkAccess('tsPurchaseEdit'))) {
            if (!(isset(Yii::app()->session['PurchaseMemoAllowed']) && Yii::app()->session['PurchaseMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('PurchaseMemoAllowed');

        $purchase = PurchaseHeader::model()->findByPk($id);

        $purchaseHeaderText = ($purchase->is_non_tax) ? '' : 'PT. Galatech Jaya Abadi';
        $purchaseSupplier = ($purchase->is_non_tax) ? $purchase->supplier->name : $purchase->supplier->company;

        $this->render('memo', array(
            'purchase' => $purchase,
            'purchaseSupplier' => $purchaseSupplier,
            'purchaseHeaderText' => $purchaseHeaderText,
        ));
    }

    public function actionMemoPickup($id) {
        if (!(Yii::app()->user->checkAccess('administrator') || Yii::app()->user->checkAccess('tPurchaseEdit') || Yii::app()->user->checkAccess('tsPurchaseEdit'))) {
            if (!(isset(Yii::app()->session['PurchaseMemoAllowed']) && Yii::app()->session['PurchaseMemoAllowed'] === true))
                $this->redirect(array('admin'));
        }

        Yii::app()->session->remove('PurchaseMemoAllowed');

        $purchase = PurchaseHeader::model()->findByPk($id);

        $purchaseHeaderText = ($purchase->is_non_tax) ? '' : 'PT. Galatech Jaya Abadi';
        $purchaseSupplier = ($purchase->is_non_tax) ? $purchase->supplier->name : $purchase->supplier->company;

        $this->render('memoPickup', array(
            'purchase' => $purchase,
            'purchaseSupplier' => $purchaseSupplier,
            'purchaseHeaderText' => $purchaseHeaderText,
        ));
    }

    public function actionAdmin() {
        $purchase = new PurchaseHeader('search');
        $purchase->unsetAttributes();

        if (isset($_GET['PurchaseHeader']))
            $purchase->attributes = $_GET['PurchaseHeader'];

        $dataProvider = $purchase->search();
        $dataProvider->model->resetScope();
        $dataProvider->criteria->with = array('admin:resetScope');

        $this->render('admin', array(
            'purchase' => $purchase,
            'dataProvider' => $dataProvider,
        ));
    }

    public function actionReport() {
        $purchaseHeader = new PurchaseHeader('search');
        $purchaseHeader->unsetAttributes();
        if (isset($_GET['PurchaseHeader']))
            $purchaseHeader->attributes = $_GET['PurchaseHeader'];

        $startDate = (isset($_GET['StartDate'])) ? $_GET['StartDate'] : '';
        $endDate = (isset($_GET['EndDate'])) ? $_GET['EndDate'] : '';
        $pageSize = (isset($_GET['PageSize'])) ? $_GET['PageSize'] : '';
        $currentPage = (isset($_GET['page'])) ? $_GET['page'] : '';
        $currentSort = (isset($_GET['sort'])) ? $_GET['sort'] : '';

        $dataProvider = $purchaseHeader->search();
        $dataProvider->criteria->with = array('supplier');

        $page = array('size' => $pageSize, 'current' => $currentPage);
        $date = array('attribute' => 'date', 'start' => $startDate, 'end' => $endDate);

        $sort = new CSort(get_class($purchaseHeader));
        $sort->attributes = array('date', 'supplier.name');

        $dataProvider = ReportHelper::finalizeDataProvider($dataProvider, $page, $sort, $date);

        if (isset($_GET['SaveExcel']))
            $this->saveToExcel($dataProvider, array('startDate' => $startDate, 'endDate' => $endDate));

        $this->render('report', array(
            'purchaseHeader' => $purchaseHeader,
            'dataProvider' => $dataProvider,
            'startDate' => $startDate,
            'endDate' => $endDate,
            'sort' => $sort,
            'currentSort' => $currentSort,
        ));
    }

    public function actionAddProductAjax($id, $nt) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchase = new Purchase();

            if (!empty($id))
                $purchase->copyFromDb($id);

            if ($purchase->header->isNewRecord)
                $purchase->header->is_non_tax = intval($nt);

            $this->loadState($purchase);

            if (isset($_POST['ProductId']))
                $purchase->addProduct($_POST['ProductId']);

            $this->renderPartial('_detail', array(
                'purchase' => $purchase,
                'error' => false,
            ));
        }
    }

    public function actionRemoveProductAjax($id, $index) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchase = new Purchase();

            if (!empty($id))
                $purchase->copyFromDb($id);

            $this->loadState($purchase);

            $purchase->removeProductAt($index);

            $this->renderPartial('_detail', array(
                'purchase' => $purchase,
                'error' => false,
            ));
        }
    }

    public function actionUpdateAllPriceAjax() {
        if (Yii::app()->request->isAjaxRequest) {
            $purchase = new Purchase();

            $this->loadState($purchase);

            $purchase->updatePrices();

            $this->renderPartial('_detail', array(
                'purchase' => $purchase,
                'error' => false,
            ));
        }
    }

    public function actionTotalAjaxData($id, $index) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchase = new Purchase();

            if (!empty($id))
                $purchase->copyFromDb($id);

            if (!isset($_POST['PurchaseDetail']))
                $purchase->details = array();

            $this->loadState($purchase);

            $unitPrice = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', CHtml::value($purchase->details[$index], 'unit_price')));
            $priceBeforeTax = round($purchase->details[$index]->getPriceAfterTax($purchase->header->tax_type, $purchase->header->tax), 2);
            $priceBeforeTaxFormat = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->details[$index]->getPriceAfterTax($purchase->header->tax_type, $purchase->header->tax)));
            $total = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->details[$index]->getTotal($purchase->header->tax_type, $purchase->header->tax)));
            $subTotal = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->subTotal));
            $subTotalQuantity = CHtml::encode(Yii::app()->numberFormatter->format('#,##0', $purchase->subTotalQuantity));
            $discount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->calculatedDiscount));
            $tax = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->calculatedTax));
            $grandTotal = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->grandTotal));

            echo CJSON::encode(array(
                'unitPrice' => $unitPrice,
                'priceBeforeTax' => $priceBeforeTax,
                'priceBeforeTaxFormat' => $priceBeforeTaxFormat,
                'total' => $total,
                'subTotal' => $subTotal,
                'discount' => $discount,
                'tax' => $tax,
                'grandTotal' => $grandTotal,
                'subTotalQuantity' => $subTotalQuantity
            ));
        }
    }

    public function actionGrandTotalAjaxData($id) {
        if (Yii::app()->request->isAjaxRequest) {
            $purchase = new Purchase();

            if (!empty($id)) {
                $purchase->copyFromDb($id);
            }

            $this->loadState($purchase);

            $discount = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->calculatedDiscount));
            $tax = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->calculatedTax));
            $grandTotal = CHtml::encode(Yii::app()->numberFormatter->format('#,##0.00', $purchase->grandTotal));

            echo CJSON::encode(array(
                'discount' => $discount,
                'tax' => $tax,
                'grandTotal' => $grandTotal,
            ));
        }
    }

    public function actionSupplierCompletion() {
        echo CJSON::encode(Completion::supplier($_GET['term']));
    }

    protected function reportGrandTotal($dataProvider) {
        $grandTotal = 0.00;

        foreach ($dataProvider->data as $data)
            $grandTotal += $data->grandTotal;

        return $grandTotal;
    }

    protected function saveToExcel($dataProvider, array $options = array()) {
        spl_autoload_unregister(array('YiiBase', 'autoload'));
        include_once Yii::getPathOfAlias('ext.phpexcel.Classes') . DIRECTORY_SEPARATOR . 'PHPExcel.php';
        spl_autoload_register(array('YiiBase', 'autoload'));

        $objPHPExcel = new PHPExcel();

        $documentProperties = $objPHPExcel->getProperties();
        $documentProperties->setCreator('PT. GALATECH JAYA ABADI');
        $documentProperties->setTitle('Laporan Pembelian Barang');

        $worksheet = $objPHPExcel->setActiveSheetIndex(0);
        $worksheet->setTitle('Pembelian');

        $worksheet->getColumnDimension('A')->setAutoSize(true);
        $worksheet->getColumnDimension('B')->setAutoSize(true);
        $worksheet->getColumnDimension('C')->setAutoSize(true);
        $worksheet->getColumnDimension('D')->setAutoSize(true);
        $worksheet->getColumnDimension('E')->setAutoSize(true);
        $worksheet->getColumnDimension('F')->setAutoSize(true);
        $worksheet->getColumnDimension('G')->setAutoSize(true);
        $worksheet->getColumnDimension('H')->setAutoSize(true);
        $worksheet->getColumnDimension('I')->setAutoSize(true);
        $worksheet->getColumnDimension('J')->setAutoSize(true);
        $worksheet->getColumnDimension('K')->setAutoSize(true);

        $worksheet->mergeCells('A1:K1');
        $worksheet->mergeCells('A2:K2');
        $worksheet->mergeCells('A3:K3');

        $worksheet->getStyle('A1:K5')->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_CENTER);
        $worksheet->getStyle('A1:K5')->getFont()->setBold(true);

        $worksheet->setCellValue('A1', 'PT. GALATECH JAYA ABADI');
        $worksheet->setCellValue('A2', 'Pembelian Barang');
        $worksheet->setCellValue('A3', Yii::app()->dateFormatter->format('d MMMM yyyy', strtotime($options['startDate'])) . ' - ' . Yii::app()->dateFormatter->format('d MMMM yyyy', strtotime($options['endDate'])));

        $worksheet->setCellValue('A5', 'Pembelian #');
        $worksheet->setCellValue('B5', 'Tanggal');
        $worksheet->setCellValue('C5', 'Faktur Supplier #');
        $worksheet->setCellValue('D5', 'Supplier');

        $worksheet->getStyle('A5:K5')->getBorders()->getBottom()->setBorderStyle(PHPExcel_Style_Border::BORDER_THICK);

        $worksheet->setCellValue('E5', 'Nama Barang');
        $worksheet->setCellValue('F5', 'Ukuran');
        $worksheet->setCellValue('G5', 'Jumlah');
        $worksheet->setCellValue('H5', 'Satuan');
        $worksheet->setCellValue('I5', 'Harga Satuan');
        $worksheet->setCellValue('J5', 'Diskon');
        $worksheet->setCellValue('K5', 'Disc Price');
        $worksheet->setCellValue('L5', 'Total');

        $counter = 8;
        foreach ($dataProvider->data as $header) {
            $worksheet->getStyle("C{$counter}")->getAlignment()->setHorizontal(PHPExcel_Style_Alignment::HORIZONTAL_LEFT);

            foreach ($header->purchaseDetails as $detail) {
                $worksheet->getStyle("F{$counter}:K{$counter}")->getNumberFormat()->setFormatCode('#,##0');
                $worksheet->setCellValue("A{$counter}", $detail->purchaseHeader->number);
                $worksheet->setCellValue("B{$counter}", Yii::app()->dateFormatter->format('d MMMM yyyy', strtotime($detail->purchaseHeader->date)));
                //$worksheet->setCellValue("C{$counter}", $detail->purchaseHeader->purchaseInvoices[0]->reference);
                $worksheet->setCellValue("D{$counter}", $detail->purchaseHeader->supplier->company);
                $worksheet->setCellValue("E{$counter}", $detail->product->name);
                $worksheet->setCellValue("F{$counter}", $detail->product->size);
                $worksheet->setCellValue("G{$counter}", $detail->quantity);
                $worksheet->setCellValue("H{$counter}", $detail->product->unit->name);
                $worksheet->setCellValue("I{$counter}", $detail->unit_price);
                $worksheet->setCellValue("J{$counter}", $detail->discount);
                $worksheet->setCellValue("K{$counter}", $detail->priceAfterDiscount);
                $worksheet->setCellValue("L{$counter}", $detail->total);

                $counter++;
            }
        }

        header('Content-Type: application/xlsx');
        header('Content-Disposition: attachment;filename="pembelian.xlsx"');
        header('Cache-Control: max-age=0');

        $objWriter = PHPExcel_IOFactory::createWriter($objPHPExcel, 'Excel2007');
        $objWriter->save('php://output');

        Yii::app()->end();
    }

    protected function loadState(&$purchase) {
        if (isset($_POST['PurchaseHeader'])) {
            $purchase->header->attributes = $_POST['PurchaseHeader'];
        }
        if (isset($_POST['PurchaseDetail'])) {
            foreach ($_POST['PurchaseDetail'] as $i => $item) {
                if (isset($purchase->details[$i]))
                    $purchase->details[$i]->attributes = $item;
                else {
                    $detail = new PurchaseDetail();
                    $detail->attributes = $item;
                    $purchase->details[] = $detail;
                }
            }
            if (count($_POST['PurchaseDetail']) < count($purchase->details))
                array_splice($purchase->details, $i + 1);
        }
    }
}
