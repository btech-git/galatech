<div style="font-weight: bold; text-align: center">
        <div style="font-size: larger">PT. GALATECH JAYA ABADI</div>
        <div style="font-size: larger">Laporan Gudang</div>
        <div><?php echo CHtml::encode(Yii::app()->dateFormatter->format('d MMMM yyyy', strtotime($startDate))) . ' &nbsp;&ndash;&nbsp; ' . CHtml::encode(Yii::app()->dateFormatter->format('d MMMM yyyy', strtotime($endDate))); ?></div>
</div>

<br />

<table class="report">
	<tr id="header1">
		<th class="width1-1">Kategori</th>
		<th class="width1-2">Nama Produk</th>
		<th class="width1-3">Ukuran</th>
		<th class="width1-4">Stok</th>
	</tr>
	<tr id="header2">
		<td colspan="4">
			<table>
				<tr>
					<th class="width2-1">Transaksi #</th>
					<th class="width2-2">Tanggal</th>
					<th class="width2-3">Jenis</th>
					<th class="width2-4">Pelaksana</th>
					<th class="width2-5">Jml Masuk</th>
					<th class="width2-6">Jml Keluar</th>
					<th class="width2-7">Gudang</th>
				</tr>
			</table>
		</td>
	</tr>
	<?php foreach ($dataProvider->data as $header): ?>
		<tr class="items1">
			<td class="width1-1"><?php echo CHtml::encode(CHtml::value($header, 'category.name')); ?></td>
			<td class="width1-2"><?php echo CHtml::encode(CHtml::value($header, 'name')); ?></td>
			<td class="width1-3"><?php echo CHtml::encode(CHtml::value($header, 'size')); ?></td>
			<td class="width1-4" style="text-align: center"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', $header->getCurrentStock())); ?></td>
		</tr>
		<tr class="items2">
			<td colspan="4">
				<table>
					<?php foreach ($header->inventories as $detail): ?>
						<tr>
							<td class="width2-1"><?php echo CHtml::encode(CHtml::value($detail, 'transaction_number')); ?></td>
							<td class="width2-2"><?php echo CHtml::encode(Yii::app()->dateFormatter->format('d MMMM yyyy', strtotime($detail->date))); ?></td>
							<td class="width2-3"><?php echo CHtml::encode(CHtml::value($detail, 'transactionType')); ?></td>
							<td class="width2-4"><?php echo CHtml::encode(CHtml::value($detail, 'transaction_subject')); ?></td>
							<td class="width2-5" style="text-align: right"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', CHtml::value($detail, 'quantity_in'))); ?></td>
							<td class="width2-6" style="text-align: right"><?php echo CHtml::encode(Yii::app()->numberFormatter->format('#,##0', CHtml::value($detail, 'quantity_out'))); ?></td>
							<td class="width2-7" style="text-align: right"><?php echo CHtml::encode(CHtml::value($detail, 'warehouse.name')); ?></td>	
						</tr>
					<?php endforeach; ?>
				</table>
			</td>
		</tr>
	<?php endforeach; ?>
</table>